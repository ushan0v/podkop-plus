#!/bin/ash

PODKOP_COMMAND="${1:-}"
PODKOP_CONFIG_NAME="${PODKOP_CONFIG_NAME:-podkop-plus}"
SB_DNS_INBOUND_ADDRESS="${SB_DNS_INBOUND_ADDRESS:-127.0.0.42}"

podkop_dnsmasq_failsafe_restore_raw() {
    local legacy_dnsmasq_section legacy_interfaces default_servers backup_servers backup_notinterfaces value
    local default_has_podkop_dns noresolv cachesize changed
    local legacy_instance_present dont_touch_dhcp podkop_managed_state

    command -v uci >/dev/null 2>&1 || return 0
    dont_touch_dhcp=0
    case "$(uci -q get "$PODKOP_CONFIG_NAME.settings.dont_touch_dhcp" 2>/dev/null)" in
    1|true|yes|on)
        dont_touch_dhcp=1
        ;;
    esac

    legacy_dnsmasq_section="podkop_plus"
    changed=0
    default_has_podkop_dns=0
    legacy_instance_present=0
    legacy_interfaces="$(uci -q get "dhcp.$legacy_dnsmasq_section.interface" 2>/dev/null)"
    [ -n "$legacy_interfaces" ] ||
        legacy_interfaces="$(uci -q get "$PODKOP_CONFIG_NAME.settings.source_network_interfaces" 2>/dev/null)"
    [ -n "$legacy_interfaces" ] || legacy_interfaces="br-lan"

    default_servers="$(uci -q get 'dhcp.@dnsmasq[0].server' 2>/dev/null)"
    for value in $default_servers; do
        [ "$value" = "$SB_DNS_INBOUND_ADDRESS" ] && default_has_podkop_dns=1
    done

    podkop_managed_state=0
    [ -n "$(uci -q get 'dhcp.@dnsmasq[0].podkop_server' 2>/dev/null)" ] && podkop_managed_state=1
    [ -n "$(uci -q get 'dhcp.@dnsmasq[0].podkop_noresolv' 2>/dev/null)" ] && podkop_managed_state=1
    [ -n "$(uci -q get 'dhcp.@dnsmasq[0].podkop_cachesize' 2>/dev/null)" ] && podkop_managed_state=1
    [ -n "$(uci -q get 'dhcp.@dnsmasq[0].podkop_notinterface' 2>/dev/null)" ] && podkop_managed_state=1

    if uci -q show "dhcp.$legacy_dnsmasq_section" >/dev/null 2>&1; then
        legacy_instance_present=1
        podkop_managed_state=1
        changed=1
    fi
    [ "$dont_touch_dhcp" -eq 0 ] || [ "$podkop_managed_state" -eq 1 ] || return 0

    uci -q delete "dhcp.$legacy_dnsmasq_section" >/dev/null 2>&1 || true

    backup_notinterfaces="$(uci -q get 'dhcp.@dnsmasq[0].podkop_notinterface' 2>/dev/null)"
    if [ -n "$backup_notinterfaces" ]; then
        uci -q delete 'dhcp.@dnsmasq[0].notinterface' >/dev/null 2>&1 || true
        for value in $backup_notinterfaces; do
            uci -q add_list "dhcp.@dnsmasq[0].notinterface=$value" >/dev/null 2>&1 || true
        done
        uci -q delete 'dhcp.@dnsmasq[0].podkop_notinterface' >/dev/null 2>&1 || true
        changed=1
    else
        if [ "$legacy_instance_present" -eq 1 ]; then
            for value in $legacy_interfaces; do
                uci -q del_list "dhcp.@dnsmasq[0].notinterface=$value" >/dev/null 2>&1 && changed=1
            done
        fi
        uci -q delete 'dhcp.@dnsmasq[0].podkop_notinterface' >/dev/null 2>&1 || true
    fi

    backup_servers="$(uci -q get 'dhcp.@dnsmasq[0].podkop_server' 2>/dev/null)"
    if [ -n "$backup_servers" ]; then
        uci -q delete 'dhcp.@dnsmasq[0].server' >/dev/null 2>&1 || true
        for value in $backup_servers; do
            uci -q add_list "dhcp.@dnsmasq[0].server=$value" >/dev/null 2>&1 || true
        done
        uci -q delete 'dhcp.@dnsmasq[0].podkop_server' >/dev/null 2>&1 || true
        changed=1
    else
        uci -q del_list "dhcp.@dnsmasq[0].server=$SB_DNS_INBOUND_ADDRESS" >/dev/null 2>&1 && changed=1
        uci -q delete 'dhcp.@dnsmasq[0].podkop_server' >/dev/null 2>&1 || true
    fi

    noresolv="$(uci -q get 'dhcp.@dnsmasq[0].podkop_noresolv' 2>/dev/null)"
    if [ -n "$noresolv" ]; then
        uci -q set "dhcp.@dnsmasq[0].noresolv=$noresolv" >/dev/null 2>&1 || true
        uci -q delete 'dhcp.@dnsmasq[0].podkop_noresolv' >/dev/null 2>&1 || true
        changed=1
    elif [ "$default_has_podkop_dns" -eq 1 ]; then
        uci -q set 'dhcp.@dnsmasq[0].noresolv=0' >/dev/null 2>&1 || true
        changed=1
    fi

    cachesize="$(uci -q get 'dhcp.@dnsmasq[0].podkop_cachesize' 2>/dev/null)"
    if [ -n "$cachesize" ]; then
        uci -q set "dhcp.@dnsmasq[0].cachesize=$cachesize" >/dev/null 2>&1 || true
        uci -q delete 'dhcp.@dnsmasq[0].podkop_cachesize' >/dev/null 2>&1 || true
        changed=1
    elif [ "$default_has_podkop_dns" -eq 1 ]; then
        uci -q set 'dhcp.@dnsmasq[0].cachesize=150' >/dev/null 2>&1 || true
        changed=1
    fi

    [ "$changed" -eq 1 ] || return 0

    uci -q commit dhcp >/dev/null 2>&1 || true
    [ -x /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
}

podkop_dnsmasq_failsafe_restore_on_loader_failure() {
    case "$PODKOP_COMMAND" in
    start | stop | restart | reload | uninstall | dnsmasq_restore | restore_dnsmasq)
        podkop_dnsmasq_failsafe_restore_raw
        ;;
    esac
}

check_required_file() {
    local file="$1"

    if [ ! -r "$file" ]; then
        echo "Error: required file '$file' is missing or not readable" >&2
        podkop_dnsmasq_failsafe_restore_on_loader_failure
        exit 1
    fi
}

PODKOP_LIB="/usr/lib/podkop-plus"
check_required_file /lib/functions.sh
check_required_file /lib/config/uci.sh
check_required_file "$PODKOP_LIB/constants.sh"
check_required_file "$PODKOP_LIB/status_diagnostics.uc"
check_required_file "$PODKOP_LIB/ui_runtime.sh"
check_required_file "$PODKOP_LIB/ui_runtime.uc"

. /lib/functions.sh
. /lib/config/uci.sh
. "$PODKOP_LIB/constants.sh"
. "$PODKOP_LIB/ui_runtime.sh"

podkop_fast_status_diagnostics_ucode() {
    ucode "$PODKOP_LIB/status_diagnostics.uc" "$@"
}

podkop_fast_ui_capabilities_server_handler() {
    local section="$1" enabled

    config_get enabled "$section" "enabled" "1"
    [ "$enabled" = "0" ] && return 0

    PODKOP_FAST_SERVER_INBOUNDS_ENABLED_COUNT=$((PODKOP_FAST_SERVER_INBOUNDS_ENABLED_COUNT + 1))
}

podkop_fast_collect_ui_capabilities() {
    local sing_box_version sing_box_output sing_box_tags

    PODKOP_FAST_SING_BOX_EXTENDED=0
    PODKOP_FAST_SING_BOX_TINY=0
    PODKOP_FAST_SING_BOX_COMPRESSED=0
    PODKOP_FAST_SING_BOX_TAILSCALE=0
    PODKOP_FAST_ZAPRET_INSTALLED=0
    PODKOP_FAST_ZAPRET2_INSTALLED=0
    PODKOP_FAST_BYEDPI_INSTALLED=0
    PODKOP_FAST_SERVER_INBOUNDS_ENABLED_COUNT=0

    if command -v sing-box >/dev/null 2>&1; then
        if ui_runtime_sing_box_compressed_marker_set; then
            PODKOP_FAST_SING_BOX_EXTENDED=1
            PODKOP_FAST_SING_BOX_COMPRESSED=1
            PODKOP_FAST_SING_BOX_TAILSCALE=1
        elif ui_runtime_sing_box_marker_is extended; then
            PODKOP_FAST_SING_BOX_EXTENDED=1
            PODKOP_FAST_SING_BOX_TAILSCALE=1
        elif ui_runtime_sing_box_tiny_package_installed || ui_runtime_sing_box_marker_is tiny; then
            PODKOP_FAST_SING_BOX_TINY=1
        elif ui_runtime_component_action_running_for sing_box; then
            PODKOP_FAST_SING_BOX_TAILSCALE=1
        else
            sing_box_output="$(sing-box version 2>/dev/null || true)"
            sing_box_version="$(printf '%s\n' "$sing_box_output" | sed -n '1{s/.*[[:space:]]//;p;q;}')"
            case "$sing_box_version" in
            *extended*)
                PODKOP_FAST_SING_BOX_EXTENDED=1
                PODKOP_FAST_SING_BOX_TAILSCALE=1
                ;;
            *)
                sing_box_tags="$(printf '%s\n' "$sing_box_output" | sed -n 's/^Tags:[[:space:]]*//p' | head -n 1)"
                printf '%s\n' "$sing_box_tags" | grep -Eq '(^|[,:[:space:]])with_tailscale([,[:space:]]|$)' &&
                    PODKOP_FAST_SING_BOX_TAILSCALE=1
                [ "$PODKOP_FAST_SING_BOX_TAILSCALE" -eq 0 ] && PODKOP_FAST_SING_BOX_TINY=1
                ;;
            esac
        fi
    fi

    [ -x "$ZAPRET_PROVIDER_NFQWS_BIN" ] && PODKOP_FAST_ZAPRET_INSTALLED=1
    [ -x "$ZAPRET2_PROVIDER_NFQWS2_BIN" ] && PODKOP_FAST_ZAPRET2_INSTALLED=1
    [ -x "$BYEDPI_BIN" ] && PODKOP_FAST_BYEDPI_INSTALLED=1

    config_load "$PODKOP_CONFIG_NAME"
    config_foreach podkop_fast_ui_capabilities_server_handler "server"
}

podkop_fast_get_ui_capabilities() {
    podkop_fast_collect_ui_capabilities

    podkop_fast_status_diagnostics_ucode ui-capabilities-json \
        "$PODKOP_FAST_SING_BOX_EXTENDED" \
        "$PODKOP_FAST_SING_BOX_TINY" \
        "$PODKOP_FAST_SING_BOX_COMPRESSED" \
        "$PODKOP_FAST_SING_BOX_TAILSCALE" \
        "$PODKOP_FAST_ZAPRET_INSTALLED" \
        "$PODKOP_FAST_ZAPRET2_INSTALLED" \
        "$PODKOP_FAST_BYEDPI_INSTALLED" \
        "${PODKOP_FAST_SERVER_INBOUNDS_ENABLED_COUNT:-0}"
}

podkop_fast_get_ui_state() {
    local podkop_running=0 podkop_enabled=0 podkop_status dns_configured=0
    local sing_box_running=0 sing_box_enabled=0 sing_box_status active_action

    podkop_fast_collect_ui_capabilities
    ui_runtime_ensure_dirs
    ui_runtime_refresh_action_dirs

    ui_runtime_sing_box_running && sing_box_running=1
    ui_runtime_sing_box_enabled && sing_box_enabled=1

    ui_runtime_podkop_running && podkop_running=1
    ui_runtime_service_enabled && podkop_enabled=1
    ui_runtime_dns_configured && dns_configured=1

    podkop_status="$(ui_runtime_status_text "$podkop_running" "$podkop_enabled")"
    sing_box_status="$(ui_runtime_status_text "$sing_box_running" "$sing_box_enabled")"

    active_action="$(ui_runtime_active_service_action 2>/dev/null || true)"
    case "$active_action" in
    start) podkop_status="starting" ;;
    stop) podkop_status="stopping" ;;
    restart) podkop_status="restarting" ;;
    reload) podkop_status="reloading" ;;
    esac

    ui_runtime_write_ui_state \
        "$podkop_running" \
        "$podkop_enabled" \
        "$podkop_status" \
        "$dns_configured" \
        "$sing_box_running" \
        "$sing_box_enabled" \
        "$sing_box_status" \
        "$PODKOP_FAST_SING_BOX_EXTENDED" \
        "$PODKOP_FAST_SING_BOX_TINY" \
        "$PODKOP_FAST_SING_BOX_COMPRESSED" \
        "$PODKOP_FAST_SING_BOX_TAILSCALE" \
        "$PODKOP_FAST_ZAPRET_INSTALLED" \
        "$PODKOP_FAST_ZAPRET2_INSTALLED" \
        "$PODKOP_FAST_BYEDPI_INSTALLED" \
        "${PODKOP_FAST_SERVER_INBOUNDS_ENABLED_COUNT:-0}"
}

case "$PODKOP_COMMAND" in
get_ui_capabilities)
    podkop_fast_get_ui_capabilities
    exit $?
    ;;
get_ui_state)
    podkop_fast_get_ui_state
    exit $?
    ;;
service_action_async)
    ui_runtime_service_action_async "$2"
    exit $?
    ;;
service_action_status)
    ui_runtime_service_action_status "$2"
    exit $?
    ;;
latency_test_async)
    ui_runtime_latency_test_async "$2" "$3" "$4" "$5"
    exit $?
    ;;
latency_test_status)
    ui_runtime_latency_test_status "$2"
    exit $?
    ;;
ui_action_ack)
    ui_runtime_action_ack "$2" "$3"
    exit $?
    ;;
esac

check_required_file /lib/functions/network.sh
