get_rule_action() {
    local section="$1"
    local action

    config_get action "$section" "action"
    echo "$action"
}

rule_is_enabled() {
    local section="$1"
    local enabled

    config_get_bool enabled "$section" "enabled" 1
    [ "$enabled" -eq 1 ]
}

server_is_enabled() {
    local section="$1"
    local enabled

    config_get_bool enabled "$section" "enabled" 0
    [ "$enabled" -eq 1 ]
}

. "$PODKOP_LIB/config_validation.sh"

. "$PODKOP_LIB/server_runtime.sh"

start_main() {
    log "Starting Podkop Plus"

    migration

    check_requirements

    prepare_all_server_defaults
    config_foreach process_validate_rule "section"
    validate_runtime_settings

    br_netfilter_disable

    # Sync time only when the system clock is clearly invalid.
    sync_time_if_needed

    sleep 1

    ensure_runtime_dirs
    acquire_start_subscription_update_lock
    if ! prepare_subscription_caches_for_startup; then
        log "Subscription caches are not ready. Aborted." "fatal"
        exit 1
    fi

    # base
    route_table_rule_mark
    create_nft_rules
    sing_box_configure_service

    # sing-box
    sing_box_init_config
    refresh_list_update_cron
    start_byedpi_runtime
    if ! /etc/init.d/sing-box start; then
        log "Failed to start sing-box. Aborted." "fatal"
        exit 1
    fi
    apply_pending_urltest_selector_switches
    run_deferred_subscription_bootstrap
    release_start_subscription_update_lock
    start_zapret_runtime
    start_zapret2_runtime

    (close_inherited_service_lock_fd; list_update) &
}

main() {
    start_main
}

stop_main() {
    local status=0

    log "Stopping Podkop Plus"

    stop_deferred_subscription_bootstrap_retry_worker

    if [ -f /var/run/podkop_list_update.pid ]; then
        pid=$(cat /var/run/podkop_list_update.pid)
        if kill -0 "$pid" 2> /dev/null; then
            kill "$pid" 2> /dev/null
            log "Stopped list_update"
        fi
        rm -f /var/run/podkop_list_update.pid
    fi

    remove_cron_job

    rm -f "$TMP_RULESET_FOLDER"/*

    stop_zapret_runtime
    stop_zapret2_runtime
    stop_byedpi_runtime

    log "Flush nft"
    if nft list table inet "$NFT_TABLE_NAME" > /dev/null 2>&1; then
        nft delete table inet "$NFT_TABLE_NAME"
    fi

    log "Flush ip rule"
    if has_tproxy_marking_rule; then
        ip rule del fwmark "$NFT_FAKEIP_MARK"/"$NFT_FAKEIP_MARK" table "$RT_TABLE_NAME" priority 105
    fi

    log "Flush ip route"
    if has_tproxy_route; then
        ip route flush table "$RT_TABLE_NAME"
    fi

    log "Stop sing-box"
    /etc/init.d/sing-box stop || status="$?"

    return "$status"
}

start_impl() {
    start_main

    config_get_bool dont_touch_dhcp "settings" "dont_touch_dhcp" 0
    if [ "$dont_touch_dhcp" -eq 0 ]; then
        dnsmasq_configure || return 1
    elif dnsmasq_has_podkop_managed_state; then
        log "dont_touch_dhcp is enabled, restoring previous Podkop Plus dnsmasq changes"
        dnsmasq_restore force || return 1
    fi

    uci_set "$PODKOP_CONFIG_NAME" "settings" "shutdown_correctly" 0
    commit_podkop_config || return 1
    capture_reload_state
    write_reload_state || return 1
    (refresh_system_info_cache) >/dev/null 2>&1 &
}

start_failure_failsafe_dnsmasq_restore() {
    local status="$1"

    trap - EXIT INT TERM
    [ "$status" -eq 0 ] && exit 0

    dnsmasq_restore_fail_safe
    exit "$status"
}

acquire_start_subscription_update_lock() {
    if acquire_runtime_dir_lock_wait "$PODKOP_SUBSCRIPTION_UPDATE_LOCK_DIR" 300; then
        PODKOP_START_SUBSCRIPTION_UPDATE_LOCK_HELD=1
        return 0
    fi

    log "Subscription update is already running during startup. Aborted." "fatal"
    exit 1
}

release_start_subscription_update_lock() {
    [ "${PODKOP_START_SUBSCRIPTION_UPDATE_LOCK_HELD:-0}" = "1" ] || return 0

    release_runtime_dir_lock "$PODKOP_SUBSCRIPTION_UPDATE_LOCK_DIR"
    PODKOP_START_SUBSCRIPTION_UPDATE_LOCK_HELD=0
}

start_exit_cleanup() {
    local status="$1"

    release_start_subscription_update_lock
    start_failure_failsafe_dnsmasq_restore "$status"
}

start() {
    local status

    trap 'start_exit_cleanup "$?"' EXIT INT TERM
    start_impl
    status="$?"
    trap - EXIT INT TERM
    release_start_subscription_update_lock

    if [ "$status" -ne 0 ]; then
        dnsmasq_restore_fail_safe
        return "$status"
    fi

    if ! wait_for_podkop_stable_start; then
        log "Podkop Plus did not reach a stable running state after start. Restoring dnsmasq." "fatal"
        dnsmasq_restore_fail_safe
        return 1
    fi

    run_pending_reload_if_requested
    return 0
}

stop_impl() {
    local dont_touch_dhcp status

    status=0
    config_get_bool dont_touch_dhcp "settings" "dont_touch_dhcp" 0
    if [ "$dont_touch_dhcp" -eq 0 ]; then
        dnsmasq_restore || status="$?"
    elif dnsmasq_has_podkop_managed_state; then
        log "dont_touch_dhcp is enabled, restoring previous Podkop Plus dnsmasq changes"
        dnsmasq_restore force || status="$?"
    fi

    stop_main || status="$?"

    uci_set "$PODKOP_CONFIG_NAME" "settings" "shutdown_correctly" 1
    commit_podkop_config || status="$?"
    clear_reload_state

    if [ "$status" -ne 0 ]; then
        dnsmasq_restore_fail_safe
    fi

    return "$status"
}

stop() {
    local status

    stop_impl
    status="$?"

    return "$status"
}

restart_runtime_for_reload() {
    local dont_touch_dhcp

    log "Reload fallback: restart Podkop Plus runtime in-process"

    stop_main
    start_main

    config_get_bool dont_touch_dhcp "settings" "dont_touch_dhcp" 0
    if [ "$dont_touch_dhcp" -eq 0 ]; then
        dnsmasq_configure force
    elif dnsmasq_has_podkop_managed_state; then
        log "dont_touch_dhcp is enabled, restoring previous Podkop Plus dnsmasq changes"
        dnsmasq_restore force
    fi

    uci_set "$PODKOP_CONFIG_NAME" "settings" "shutdown_correctly" 0
    commit_podkop_config
    capture_reload_state
    write_reload_state
}

reload() {
    local reload_reason="${1:-}"
    local status
    local force_runtime_reload=0
    local previous_service_trigger_signature previous_dnsmasq_signature previous_sing_box_signature previous_nft_signature
    local previous_zapret_queue_signature previous_zapret_runtime_signature previous_zapret2_queue_signature previous_zapret2_runtime_signature previous_byedpi_runtime_signature previous_list_signature previous_cron_signature
    local previous_urltest_enabled_sections previous_urltest_enabled_sections_known needs_sing_box_reload needs_nft_rebuild needs_zapret_restart needs_zapret2_restart needs_byedpi_restart
    local needs_dnsmasq_configure needs_dnsmasq_restore needs_cron_refresh needs_list_update
    local changed_service_triggers changed_dnsmasq changed_sing_box changed_nft changed_zapret_queue changed_zapret_runtime changed_zapret2_queue changed_zapret2_runtime changed_byedpi_runtime changed_cron changed_list

    log "Podkop Plus reload"

    [ "$reload_reason" = "on_config_change" ] || force_runtime_reload=1

    migration
    config_load "$PODKOP_CONFIG_NAME"
    check_requirements
    prepare_all_server_defaults
    config_foreach process_validate_rule "section"
    validate_runtime_settings
    ensure_runtime_dirs

    if ! podkop_is_running; then
        log "Podkop Plus runtime is incomplete, falling back to in-process restart"
        restart_runtime_for_reload
        status="$?"
        return "$status"
    fi

    if ! reload_state_is_compatible; then
        log "Reload state is missing or incompatible, falling back to in-process restart"
        restart_runtime_for_reload
        status="$?"
        return "$status"
    fi

    previous_service_trigger_signature="$(read_reload_state_value "service_trigger_signature")"
    [ -n "$previous_service_trigger_signature" ] ||
        previous_service_trigger_signature="$(read_reload_state_value "restart_signature")"
    previous_dnsmasq_signature="$(read_reload_state_value "dnsmasq_signature")"
    previous_sing_box_signature="$(read_reload_state_value "sing_box_signature")"
    previous_nft_signature="$(read_reload_state_value "nft_signature")"
    previous_zapret_queue_signature="$(read_reload_state_value "zapret_queue_signature")"
    previous_zapret_runtime_signature="$(read_reload_state_value "zapret_runtime_signature")"
    previous_zapret2_queue_signature="$(read_reload_state_value "zapret2_queue_signature")"
    previous_zapret2_runtime_signature="$(read_reload_state_value "zapret2_runtime_signature")"
    previous_byedpi_runtime_signature="$(read_reload_state_value "byedpi_runtime_signature")"
    previous_list_signature="$(read_reload_state_value "list_signature")"
    previous_cron_signature="$(read_reload_state_value "cron_signature")"
    previous_urltest_enabled_sections_known=0
    if reload_state_has_key "urltest_enabled_sections"; then
        previous_urltest_enabled_sections_known=1
        previous_urltest_enabled_sections="$(read_reload_state_value "urltest_enabled_sections")"
    else
        previous_urltest_enabled_sections=""
    fi
    capture_reload_state
    if [ "$previous_urltest_enabled_sections_known" -eq 1 ]; then
        PODKOP_URLTEST_NEW_ENABLED_SECTIONS="$(
            build_new_urltest_enabled_sections "$previous_urltest_enabled_sections" "$RELOAD_STATE_URLTEST_ENABLED_SECTIONS"
        )"
    else
        PODKOP_URLTEST_NEW_ENABLED_SECTIONS=""
    fi

    needs_sing_box_reload=0
    needs_nft_rebuild=0
    needs_zapret_restart=0
    needs_zapret2_restart=0
    needs_byedpi_restart=0
    needs_dnsmasq_configure=0
    needs_dnsmasq_restore=0
    needs_cron_refresh=0
    needs_list_update=0
    changed_service_triggers=0
    changed_dnsmasq=0
    changed_sing_box=0
    changed_nft=0
    changed_zapret_queue=0
    changed_zapret_runtime=0
    changed_zapret2_queue=0
    changed_zapret2_runtime=0
    changed_byedpi_runtime=0
    changed_cron=0
    changed_list=0

    [ "$RELOAD_STATE_SERVICE_TRIGGER_SIGNATURE" != "$previous_service_trigger_signature" ] && changed_service_triggers=1

    if [ "$RELOAD_STATE_SING_BOX_SIGNATURE" != "$previous_sing_box_signature" ]; then
        changed_sing_box=1
        needs_sing_box_reload=1
    fi

    if [ "$RELOAD_STATE_NFT_SIGNATURE" != "$previous_nft_signature" ]; then
        changed_nft=1
        needs_nft_rebuild=1
    fi

    if [ "$RELOAD_STATE_ZAPRET_QUEUE_SIGNATURE" != "$previous_zapret_queue_signature" ]; then
        changed_zapret_queue=1
        needs_zapret_restart=1
        needs_nft_rebuild=1
        needs_sing_box_reload=1
    fi

    if [ "$RELOAD_STATE_ZAPRET_RUNTIME_SIGNATURE" != "$previous_zapret_runtime_signature" ]; then
        changed_zapret_runtime=1
        needs_zapret_restart=1
    fi

    if [ "$RELOAD_STATE_ZAPRET2_QUEUE_SIGNATURE" != "$previous_zapret2_queue_signature" ]; then
        changed_zapret2_queue=1
        needs_zapret2_restart=1
        needs_nft_rebuild=1
        needs_sing_box_reload=1
    fi

    if [ "$RELOAD_STATE_ZAPRET2_RUNTIME_SIGNATURE" != "$previous_zapret2_runtime_signature" ]; then
        changed_zapret2_runtime=1
        needs_zapret2_restart=1
    fi

    if [ "$RELOAD_STATE_BYEDPI_RUNTIME_SIGNATURE" != "$previous_byedpi_runtime_signature" ]; then
        changed_byedpi_runtime=1
        needs_byedpi_restart=1
    fi

    if [ "$RELOAD_STATE_DNSMASQ_SIGNATURE" != "$previous_dnsmasq_signature" ]; then
        changed_dnsmasq=1
        if [ "$RELOAD_STATE_DONT_TOUCH_DHCP" -eq 0 ]; then
            needs_dnsmasq_configure=1
        elif dnsmasq_has_podkop_managed_state; then
            needs_dnsmasq_restore=1
        fi
    fi

    if [ "$RELOAD_STATE_CRON_SIGNATURE" != "$previous_cron_signature" ]; then
        changed_cron=1
        needs_cron_refresh=1
    fi

    if [ "$RELOAD_STATE_LIST_SIGNATURE" != "$previous_list_signature" ]; then
        changed_list=1
        has_list_update_sources && needs_list_update=1
    fi

    if [ "$needs_nft_rebuild" -eq 1 ] && has_nft_list_update_sources; then
        needs_list_update=1
    fi

    if [ "$force_runtime_reload" -eq 1 ] &&
        [ "$needs_sing_box_reload" -eq 0 ] &&
        [ "$needs_nft_rebuild" -eq 0 ] &&
        [ "$needs_zapret_restart" -eq 0 ] &&
        [ "$needs_zapret2_restart" -eq 0 ] &&
        [ "$needs_byedpi_restart" -eq 0 ] &&
        [ "$needs_dnsmasq_configure" -eq 0 ] &&
        [ "$needs_dnsmasq_restore" -eq 0 ]; then
        needs_sing_box_reload=1
    fi

    log "Reload signature changes: service_triggers=$changed_service_triggers sing-box=$changed_sing_box nft=$changed_nft zapret_queue=$changed_zapret_queue zapret_runtime=$changed_zapret_runtime zapret2_queue=$changed_zapret2_queue zapret2_runtime=$changed_zapret2_runtime byedpi_runtime=$changed_byedpi_runtime dnsmasq=$changed_dnsmasq cron=$changed_cron list=$changed_list forced=$force_runtime_reload" "debug"
    log "Reload plan: sing-box=$needs_sing_box_reload nft=$needs_nft_rebuild zapret=$needs_zapret_restart zapret2=$needs_zapret2_restart byedpi=$needs_byedpi_restart dnsmasq_configure=$needs_dnsmasq_configure dnsmasq_restore=$needs_dnsmasq_restore cron=$needs_cron_refresh list_update=$needs_list_update" "debug"

    if [ "$needs_sing_box_reload" -eq 0 ] &&
        [ "$needs_nft_rebuild" -eq 0 ] &&
        [ "$needs_zapret_restart" -eq 0 ] &&
        [ "$needs_zapret2_restart" -eq 0 ] &&
        [ "$needs_byedpi_restart" -eq 0 ] &&
        [ "$needs_dnsmasq_configure" -eq 0 ] &&
        [ "$needs_dnsmasq_restore" -eq 0 ] &&
        [ "$needs_cron_refresh" -eq 0 ] &&
        [ "$needs_list_update" -eq 0 ]; then
        write_reload_state
        log "Reload skipped: runtime-relevant configuration is unchanged"
        return 0
    fi

    if [ "$needs_zapret_restart" -eq 1 ]; then
        stop_zapret_runtime
    fi

    if [ "$needs_zapret2_restart" -eq 1 ]; then
        stop_zapret2_runtime
    fi

    if [ "$needs_byedpi_restart" -eq 1 ]; then
        stop_byedpi_runtime
    fi

    if [ "$needs_nft_rebuild" -eq 1 ]; then
        rebuild_nft_runtime
    fi

    if [ "$needs_sing_box_reload" -eq 1 ]; then
        sing_box_configure_service
        if [ "$needs_nft_rebuild" -eq 1 ]; then
            PODKOP_NFT_POPULATE_ENABLED=1
        else
            PODKOP_NFT_POPULATE_ENABLED=0
        fi
        sing_box_init_config
        PODKOP_NFT_POPULATE_ENABLED=1
        reload_sing_box_runtime
        apply_pending_urltest_selector_switches
    elif [ "$needs_nft_rebuild" -eq 1 ]; then
        populate_nft_runtime_sets
    fi

    if [ "$needs_zapret_restart" -eq 1 ]; then
        start_zapret_runtime
    fi

    if [ "$needs_zapret2_restart" -eq 1 ]; then
        start_zapret2_runtime
    fi

    if [ "$needs_byedpi_restart" -eq 1 ]; then
        start_byedpi_runtime
    fi

    if [ "$needs_dnsmasq_configure" -eq 1 ]; then
        dnsmasq_configure force
        capture_reload_state
    elif [ "$needs_dnsmasq_restore" -eq 1 ]; then
        log "dont_touch_dhcp is enabled, restoring previous Podkop Plus dnsmasq changes"
        dnsmasq_restore force
        capture_reload_state
    fi

    if [ "$needs_cron_refresh" -eq 1 ]; then
        refresh_list_update_cron
    fi

    if [ "$needs_list_update" -eq 1 ]; then
        (close_inherited_service_lock_fd; list_update) &
    fi

    write_reload_state
    return 0
}

reload_tracked() {
    local reload_reason="${1:-}"
    local job_id="" state_file="" status job_pid

    if [ "${PODKOP_UI_ACTION_TRACKED:-0}" = "1" ]; then
        reload "$reload_reason"
        return "$?"
    fi

    job_id="$(ui_runtime_service_action_begin_if_idle reload "runtime_reload" 2>/dev/null || true)"
    if [ -n "$job_id" ]; then
        state_file="$(ui_runtime_job_state_path "$PODKOP_UI_SERVICE_ACTION_DIR" "$job_id" 2>/dev/null || true)"
        [ -n "$state_file" ] && ui_runtime_update_running_pid "$state_file" "$$" >/dev/null 2>&1 || true
    fi

    reload "$reload_reason"
    status="$?"

    if [ -z "$job_id" ] || [ -z "$state_file" ]; then
        return "$status"
    fi

    if [ "$status" -ne 0 ]; then
        ui_runtime_service_action_finish_job "$job_id" false "Service reload failed" "$status" >/dev/null 2>&1 || true
        return "$status"
    fi

    if ui_runtime_service_enabled || ui_runtime_podkop_running; then
        (
            trap '' HUP
            if ui_runtime_service_action_wait_for_expected_state reload; then
                ui_runtime_service_action_finish_job "$job_id" true "Service reload completed" 0
            else
                ui_runtime_service_action_finish_job "$job_id" false "Service reload did not reach expected state" 1
            fi
        ) >/dev/null 2>&1 &
        job_pid="$!"
        ui_runtime_update_running_pid "$state_file" "$job_pid" >/dev/null 2>&1 || true
    else
        ui_runtime_service_action_finish_job "$job_id" true "Service reload completed" 0 >/dev/null 2>&1 || true
    fi

    return "$status"
}

restart() {
    local status

    log "Podkop Plus restart"

    stop_impl
    status="$?"
    if [ "$status" -ne 0 ]; then
        return "$status"
    fi

    start_impl
    status="$?"

    [ "$status" -eq 0 ] && podkop_is_stably_running && run_pending_reload_if_requested
    return "$status"
}

package_manager_remove_if_installed() {
    local package_name="$1"

    if command -v apk >/dev/null 2>&1; then
        apk info -e "$package_name" >/dev/null 2>&1 && apk del "$package_name" >/dev/null 2>&1 || true
        return 0
    fi

    if opkg_package_is_installed "$package_name"; then
        opkg remove --force-depends "$package_name" >/dev/null 2>&1 || true
    fi
}

uninstall() {
    log "Uninstalling Podkop Plus"

    if [ -x "$PODKOP_SERVICE_INIT" ]; then
        stop >/dev/null 2>&1 || true
        "$PODKOP_SERVICE_INIT" disable >/dev/null 2>&1 || true
    fi

    dnsmasq_restore_fail_safe >/dev/null 2>&1 || true

    if [ -x /etc/init.d/podkop ]; then
        /etc/init.d/podkop stop >/dev/null 2>&1 || true
        /etc/init.d/podkop disable >/dev/null 2>&1 || true
    fi

    package_manager_remove_if_installed "luci-i18n-podkop-plus-ru"
    package_manager_remove_if_installed "luci-app-podkop-plus"

    if command -v sing_box_managed_service_installed >/dev/null 2>&1 && sing_box_managed_service_installed; then
        sing_box_remove_managed_service_script >/dev/null 2>&1 || true
        rm -f /usr/bin/sing-box /usr/lib/libcronet.so
    fi

    rm -rf /usr/lib/podkop-plus
    rm -rf "$PODKOP_LUCI_VIEW_DIR"
    rm -f "$PODKOP_SERVICE_INIT"
    rm -f "$PODKOP_BIN"
    rm -f /usr/share/luci/menu.d/luci-app-podkop-plus.json
    rm -f /usr/share/rpcd/acl.d/luci-app-podkop-plus.json
    rm -f /etc/uci-defaults/50_luci-podkop-plus
    rm -f "/usr/lib/lua/luci/i18n/${PODKOP_LUCI_I18N_DOMAIN}."*.lmo
    rm -f "/usr/lib/lua/luci/i18n/${PODKOP_LUCI_I18N_DOMAIN}.ru.lua"
    rm -f "/usr/lib/lua/luci/i18n/${PODKOP_LUCI_I18N_DOMAIN}.en.lua"
    rm -f /var/luci-indexcache*
    rm -f /tmp/luci-indexcache*
    [ -x /etc/init.d/rpcd ] && /etc/init.d/rpcd reload >/dev/null 2>&1 || true

    printf '%s\n' '{"removed":true}'
}

. "$PODKOP_LIB/rules_nft_runtime.sh"

. "$PODKOP_LIB/updates_runtime.sh"

. "$PODKOP_LIB/sing_box_runtime.sh"

. "$PODKOP_LIB/status_diagnostics.sh"

show_help() {
    cat << EOF
Usage: $0 COMMAND

Available commands:
    start                   Start Podkop Plus service
    stop                    Stop Podkop Plus service
    reload                  Reload Podkop Plus configuration
    restart                 Restart Podkop Plus service
    enable                  Enable Podkop Plus autostart
    disable                 Disable Podkop Plus autostart
    uninstall               Remove Podkop Plus files installed outside opkg/apk
    main                    Run main Podkop Plus process
    list_update             Update remote lists
    list_update_if_due      Update remote lists only when the configured interval has elapsed
    subscription_update [rule] [source_index]
                            Update all subscription proxies, one rule, or one source in a rule
    subscription_update_async [rule] [source_index]
                            Start forced subscription update in the background
    subscription_update_status [job_id]
                            Get background subscription update status
    subscription_update_if_due
                            Update subscription proxies only when per-rule intervals have elapsed
    check_proxy             Check proxy connectivity
    check_nft               Check NFT rules
    check_nft_rules         Check NFT rules status
    check_sing_box          Check sing-box installation and status
    check_inbounds_config   Check whether enabled server inbounds are configured
    check_inbounds          Check server inbounds from the Servers tab
    check_logs              Show Podkop Plus logs from system journal
    check_sing_box_logs     Show sing-box logs
    check_fakeip            Test sing-box FakeIP DNS
    check_zapret_runtime    Check external zapret provider state
    check_zapret2_runtime   Check external zapret2 provider state
    check_byedpi_runtime    Check external ByeDPI provider state
    neutralize_zapret_defaults
                            Compatibility no-op; Podkop Plus does not manage standalone zapret
    clash_api               Clash API interface for managing proxies and groups
    show_config             Display current Podkop Plus configuration
    show_version            Show Podkop Plus version
    show_sing_box_config    Show sing-box configuration
    show_sing_box_version   Show sing-box version
    get_status              Get Podkop Plus service status
    get_outbound_link       Get source proxy link for a generated outbound
    get_outbound_metadata   Get generated outbound display names and countries
    get_subscription_metadata
                            Get UI-only metadata for a subscription rule
    get_sing_box_status     Get sing-box service status
    get_zapret_status       Get zapret provider and Podkop Plus-managed nfqws status
    get_zapret2_status      Get zapret2 provider and Podkop Plus-managed nfqws2 status
    get_byedpi_status       Get ByeDPI provider and Podkop Plus-managed ciadpi status
    get_system_info         Get system information in JSON format
    get_server_capabilities Get server UI capabilities in JSON format
    get_ui_capabilities     Get lightweight UI capabilities in JSON format
    get_ui_state            Get lightweight UI service/action state in JSON format
    service_action_async    Start a service action in the background
    service_action_status   Get background service action status
    latency_test_async      Start a dashboard latency test in the background
    latency_test_status     Get background latency test status
    ui_action_ack           Acknowledge a finished UI action state
    generate_reality_keypair
                            Generate a sing-box Reality key pair in JSON format
    get_tls_certificate_sha256 [server]
                            Get a server TLS certificate SHA-256 fingerprint in JSON format
    component_action        Manage Podkop Plus, sing-box, zapret, zapret2, and ByeDPI components
    component_action_async  Start a component action in the background
    component_action_status Get background component action status
    check_dns_available     Check DNS server availability
    global_check            Run global system check
    validate_nfqws_strategy_json
                            Validate an NFQWS strategy and print JSON result
    validate_nfqws2_strategy_json
                            Validate an NFQWS2 strategy and print JSON result
    validate_byedpi_strategy_json
                            Validate a ByeDPI ciadpi strategy and print JSON result
EOF
}

