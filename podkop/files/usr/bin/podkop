#!/bin/ash

check_required_file() {
    local file="$1"

    if [ ! -r "$file" ]; then
        echo "Error: required file '$file' is missing or not readable" >&2
        exit 1
    fi
}

PODKOP_LIB="/usr/lib/podkop-plus"
check_required_file /lib/functions.sh
check_required_file /lib/config/uci.sh
check_required_file /lib/functions/network.sh
check_required_file "$PODKOP_LIB/constants.sh"
check_required_file "$PODKOP_LIB/nft.sh"
check_required_file "$PODKOP_LIB/helpers.sh"
check_required_file "$PODKOP_LIB/zapret.sh"
check_required_file "$PODKOP_LIB/sing_box_config_manager.sh"
check_required_file "$PODKOP_LIB/sing_box_config_facade.sh"
check_required_file "$PODKOP_LIB/subscription_parser.sh"
check_required_file "$PODKOP_LIB/logging.sh"
check_required_file "$PODKOP_LIB/rulesets.sh"
. /lib/functions.sh
. /lib/config/uci.sh
. /lib/functions/network.sh
. "$PODKOP_LIB/constants.sh"
. "$PODKOP_LIB/nft.sh"
. "$PODKOP_LIB/helpers.sh"
. "$PODKOP_LIB/zapret.sh"
. "$PODKOP_LIB/sing_box_config_manager.sh"
. "$PODKOP_LIB/sing_box_config_facade.sh"
. "$PODKOP_LIB/subscription_parser.sh"
. "$PODKOP_LIB/logging.sh"
. "$PODKOP_LIB/rulesets.sh"

PODKOP_INTERNAL_CONFIG_TRIGGER_GUARD="/var/run/podkop-plus.internal-config-change"
PODKOP_RUNTIME_STATE_DIR="/var/run/podkop-plus"
PODKOP_RUNTIME_STATUS_FILE="$PODKOP_RUNTIME_STATE_DIR/status"
PODKOP_SYSTEM_INFO_CACHE_FILE="$PODKOP_RUNTIME_STATE_DIR/system-info.json"
PODKOP_RELOAD_STATE_FILE="$PODKOP_RUNTIME_STATE_DIR/reload-state"
PODKOP_PENDING_RELOAD_FILE="$PODKOP_RUNTIME_STATE_DIR/reload.pending"
PODKOP_RESTART_INTENT_FILE="$PODKOP_RUNTIME_STATE_DIR/restart.intent"
PODKOP_LIST_UPDATE_STATE_FILE="$PODKOP_RUNTIME_STATE_DIR/list-update.timestamp"
PODKOP_SUBSCRIPTION_UPDATE_STATE_DIR="$PODKOP_RUNTIME_STATE_DIR/subscription-update"
PODKOP_SUBSCRIPTION_LINKS_DIR="$PODKOP_RUNTIME_STATE_DIR/subscription-links"
PODKOP_SUBSCRIPTION_METADATA_DIR="$PODKOP_RUNTIME_STATE_DIR/subscription-metadata"
PODKOP_SUBSCRIPTION_UPDATE_LOCK_DIR="$PODKOP_RUNTIME_STATE_DIR/subscription-update.lock"
PODKOP_RELOAD_LOCK_DIR="/var/run/podkop-plus.reload.lock"
PODKOP_LIST_UPDATE_CRON_MARKER="# podkop-plus-list-update"
PODKOP_SUBSCRIPTION_UPDATE_CRON_MARKER="# podkop-plus-subscription-update"
# sing-box falls back to 1d when update_interval is empty, so use a large
# duration to emulate disabled automatic refreshes for remote rule sets.
SING_BOX_DISABLED_UPDATE_INTERVAL="876000h"
PODKOP_RELOAD_STATE_FORMAT=1
PODKOP_RUNTIME_STATUS_FORMAT=1
PODKOP_RUNTIME_TRANSITION_MAX_AGE=300
PODKOP_RUNTIME_TRANSITION_DEAD_PID_GRACE=15
PODKOP_RUNTIME_STABLE_MIN_AGE=2
PODKOP_RUNTIME_STABLE_WAIT_TIMEOUT=8
PODKOP_SYSTEM_INFO_CACHE_TTL=3600
PODKOP_NFT_POPULATE_ENABLED=1
PODKOP_ZAPRET_MISSING_WARNING_EMITTED=0

config_load "$PODKOP_CONFIG_NAME"

ensure_runtime_dirs() {
    mkdir -p "$TMP_SING_BOX_FOLDER"
    mkdir -p "$TMP_RULESET_FOLDER"
    mkdir -p "$TMP_SUBSCRIPTION_FOLDER"
    mkdir -p "$PODKOP_RUNTIME_STATE_DIR"
    mkdir -p "$PODKOP_SUBSCRIPTION_UPDATE_STATE_DIR"
    mkdir -p "$PODKOP_SUBSCRIPTION_LINKS_DIR"
    mkdir -p "$PODKOP_SUBSCRIPTION_METADATA_DIR"
}

get_subscription_json_path() {
    local section="$1"

    echo "$TMP_SUBSCRIPTION_FOLDER/${section}.json"
}

get_subscription_url_cache_path() {
    local section="$1"

    echo "$TMP_SUBSCRIPTION_FOLDER/${section}.url"
}

get_subscription_user_agent_cache_path() {
    local section="$1"

    echo "$TMP_SUBSCRIPTION_FOLDER/${section}.user_agent"
}

get_subscription_update_timestamp_path() {
    local section="$1"

    echo "$PODKOP_SUBSCRIPTION_UPDATE_STATE_DIR/${section}.timestamp"
}

get_subscription_links_path() {
    local section="$1"

    echo "$PODKOP_SUBSCRIPTION_LINKS_DIR/${section}.json"
}

get_subscription_metadata_path() {
    local section="$1"

    echo "$PODKOP_SUBSCRIPTION_METADATA_DIR/${section}.json"
}

write_subscription_outbound_links() {
    local section="$1"
    local links_json="$2"
    local links_path tmpfile

    mkdir -p "$PODKOP_SUBSCRIPTION_LINKS_DIR"
    links_path="$(get_subscription_links_path "$section")"
    tmpfile="${links_path}.$$"

    if [ -n "$links_json" ] && printf '%s' "$links_json" | jq -e 'type == "object"' >/dev/null 2>&1; then
        printf '%s\n' "$links_json" > "$tmpfile" && mv "$tmpfile" "$links_path"
    else
        rm -f "$links_path" "$tmpfile"
    fi
}

write_subscription_metadata() {
    local section="$1"
    local metadata_path="$2"
    local target_path tmpfile

    mkdir -p "$PODKOP_SUBSCRIPTION_METADATA_DIR"
    target_path="$(get_subscription_metadata_path "$section")"
    tmpfile="${target_path}.$$"

    if [ -n "$metadata_path" ] &&
        [ -s "$metadata_path" ] &&
        jq -e 'type == "object" and (keys | length > 1)' "$metadata_path" >/dev/null 2>&1; then
        cp "$metadata_path" "$tmpfile" && mv "$tmpfile" "$target_path"
    else
        rm -f "$target_path" "$tmpfile"
    fi
}

subscription_url_is_current() {
    local section="$1"
    local subscription_url="$2"
    local current_subscription_url

    current_subscription_url="$(uci -q get "$PODKOP_CONFIG_NAME.$section.subscription_url" 2>/dev/null)"
    [ "$current_subscription_url" = "$subscription_url" ]
}

subscription_config_is_current() {
    local section="$1"
    local subscription_url="$2"
    local subscription_user_agent="${3:-}"
    local current_subscription_url current_subscription_user_agent

    current_subscription_url="$(uci -q get "$PODKOP_CONFIG_NAME.$section.subscription_url" 2>/dev/null)"
    current_subscription_user_agent="$(uci -q get "$PODKOP_CONFIG_NAME.$section.subscription_user_agent" 2>/dev/null)"

    [ "$current_subscription_url" = "$subscription_url" ] &&
        [ "$current_subscription_user_agent" = "$subscription_user_agent" ]
}

subscription_cache_is_usable() {
    local subscription_json_path="$1"

    [ -s "$subscription_json_path" ] || return 1

    validate_subscription_file "$subscription_json_path"
}

wait_for_subscription_connectivity() {
    local section="$1"
    local subscription_url="$2"
    local service_proxy_address="$3"
    local attempts="${4:-3}"
    local wait="${5:-5}"
    local timeout="${6:-5}"
    local subscription_user_agent="${7:-}"
    local attempt

    for attempt in $(seq 1 "$attempts"); do
        if check_subscription_connectivity "$subscription_url" "$service_proxy_address" 1 0 "$timeout" "$subscription_user_agent"; then
            log "Subscription connectivity check passed for rule '$section'" "info"
            return 0
        fi

        log "Subscription source is unavailable for rule '$section' [$attempt/$attempts]" "warn"
        [ "$attempt" -lt "$attempts" ] && sleep "$wait"
    done

    log "Subscription connectivity check failed for rule '$section' after $attempts attempts" "error"
    return 1
}

download_subscription_into_cache() {
    local section="$1"
    local subscription_url="$2"
    local subscription_json_path="$3"
    local subscription_url_cache_path="$4"
    local service_proxy_address="$5"
    local subscription_user_agent="${6:-}"
    local subscription_user_agent_cache_path raw_tmpfile headers_tmpfile normalized_tmpfile metadata_tmpfile

    mkdir -p "$TMP_SUBSCRIPTION_FOLDER"
    subscription_user_agent_cache_path="$(get_subscription_user_agent_cache_path "$section")"
    raw_tmpfile="$(mktemp "$TMP_SUBSCRIPTION_FOLDER/${section}.download.XXXXXX")" || return 1
    headers_tmpfile="$(mktemp "$TMP_SUBSCRIPTION_FOLDER/${section}.headers.XXXXXX")" || {
        rm -f "$raw_tmpfile"
        return 1
    }
    normalized_tmpfile="$(mktemp "$TMP_SUBSCRIPTION_FOLDER/${section}.normalized.XXXXXX")" || {
        rm -f "$raw_tmpfile" "$headers_tmpfile"
        return 1
    }
    metadata_tmpfile="$(mktemp "$TMP_SUBSCRIPTION_FOLDER/${section}.metadata.XXXXXX")" || {
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile"
        return 1
    }

    if ! download_subscription "$subscription_url" "$raw_tmpfile" "$service_proxy_address" 3 2 10 "$headers_tmpfile" "$subscription_user_agent"; then
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile" "$metadata_tmpfile"
        return 1
    fi

    subscription_extract_ui_metadata "$headers_tmpfile" "$raw_tmpfile" "$metadata_tmpfile" >/dev/null 2>&1 || rm -f "$metadata_tmpfile"

    if ! normalize_subscription_file "$raw_tmpfile" "$normalized_tmpfile" "$section"; then
        log "Downloaded subscription for rule '$section' is invalid" "error"
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile" "$metadata_tmpfile"
        return 1
    fi

    if ! validate_subscription_file "$normalized_tmpfile"; then
        log "Normalized subscription for rule '$section' is invalid" "error"
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile" "$metadata_tmpfile"
        return 1
    fi

    if ! subscription_config_is_current "$section" "$subscription_url" "$subscription_user_agent"; then
        log "Subscription source settings changed while updating rule '$section'; discarding superseded download" "warn"
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile" "$metadata_tmpfile"
        return 4
    fi

    if [ -f "$subscription_json_path" ] && cmp -s "$normalized_tmpfile" "$subscription_json_path"; then
        write_subscription_metadata "$section" "$metadata_tmpfile"
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile" "$metadata_tmpfile"
        printf '%s' "$subscription_url" > "$subscription_url_cache_path"
        printf '%s' "$subscription_user_agent" > "$subscription_user_agent_cache_path"
        log "Subscription for rule '$section' is unchanged" "info"
        return 2
    fi

    mv "$normalized_tmpfile" "$subscription_json_path" || {
        rm -f "$raw_tmpfile" "$headers_tmpfile" "$normalized_tmpfile" "$metadata_tmpfile"
        return 1
    }

    write_subscription_metadata "$section" "$metadata_tmpfile"
    rm -f "$raw_tmpfile" "$headers_tmpfile" "$metadata_tmpfile"
    printf '%s' "$subscription_url" > "$subscription_url_cache_path"
    printf '%s' "$subscription_user_agent" > "$subscription_user_agent_cache_path"
    return 0
}

rule_is_subscription_proxy() {
    local section="$1"
    local action proxy_config_type

    rule_is_enabled "$section" || return 1

    action="$(get_rule_action "$section")"
    [ "$action" = "proxy" ] || return 1

    proxy_config_type="$(get_proxy_config_type "$section")"
    [ "$proxy_config_type" = "subscription" ]
}

prepare_subscription_cache_for_startup() {
    local section="$1"
    local subscription_url subscription_user_agent subscription_json_path subscription_url_cache_path \
        subscription_user_agent_cache_path cached_subscription_url cached_subscription_user_agent
    local had_usable_cache cache_needs_refresh

    rule_is_subscription_proxy "$section" || return 0

    config_get subscription_url "$section" "subscription_url"
    config_get subscription_user_agent "$section" "subscription_user_agent" ""
    if [ -z "$subscription_url" ]; then
        log "Subscription URL is not set for rule '$section'. Aborted." "fatal"
        exit 1
    fi

    subscription_json_path="$(get_subscription_json_path "$section")"
    subscription_url_cache_path="$(get_subscription_url_cache_path "$section")"
    subscription_user_agent_cache_path="$(get_subscription_user_agent_cache_path "$section")"
    cached_subscription_url=""
    cached_subscription_user_agent=""
    had_usable_cache=0
    cache_needs_refresh=0

    if subscription_cache_is_usable "$subscription_json_path"; then
        had_usable_cache=1
    else
        rm -f "$subscription_json_path"
    fi

    if [ -f "$subscription_url_cache_path" ]; then
        cached_subscription_url="$(cat "$subscription_url_cache_path" 2> /dev/null)"
    fi

    if [ -f "$subscription_user_agent_cache_path" ]; then
        cached_subscription_user_agent="$(cat "$subscription_user_agent_cache_path" 2> /dev/null)"
    fi

    if [ "$had_usable_cache" -eq 0 ] ||
        [ "$cached_subscription_url" != "$subscription_url" ] ||
        [ "$cached_subscription_user_agent" != "$subscription_user_agent" ]; then
        cache_needs_refresh=1
    fi

    [ "$cache_needs_refresh" -eq 0 ] && return 0

    download_subscription_into_cache \
        "$section" "$subscription_url" "$subscription_json_path" "$subscription_url_cache_path" "" "$subscription_user_agent"
    case "$?" in
    0 | 2) return 0 ;;
    esac

    if [ "$had_usable_cache" -eq 1 ] &&
        [ "$cached_subscription_url" = "$subscription_url" ] &&
        [ "$cached_subscription_user_agent" = "$subscription_user_agent" ]; then
        log "Keeping cached subscription for rule '$section' until a fresh download succeeds" "warn"
        return 0
    fi

    log "No usable subscription cache for rule '$section'; startup cannot continue" "error"
    subscription_startup_blocked=1
    return 1
}

prepare_subscription_caches_for_startup() {
    subscription_startup_blocked=0
    config_foreach prepare_subscription_cache_for_startup "rule"

    [ "$subscription_startup_blocked" -eq 0 ]
}

close_inherited_service_lock_fd() {
    exec 1000>&- 2>/dev/null || true
}

acquire_runtime_dir_lock() {
    local lock_dir="$1"
    local owner_pid

    if mkdir "$lock_dir" 2>/dev/null; then
        printf '%s\n' "$$" > "$lock_dir/pid"
        return 0
    fi

    owner_pid="$(sed -n '1p' "$lock_dir/pid" 2>/dev/null)"
    if [ -n "$owner_pid" ] && kill -0 "$owner_pid" 2>/dev/null; then
        return 1
    fi

    rm -f "$lock_dir/pid" 2>/dev/null
    rmdir "$lock_dir" 2>/dev/null || return 1
    mkdir "$lock_dir" 2>/dev/null || return 1
    printf '%s\n' "$$" > "$lock_dir/pid"
}

release_runtime_dir_lock() {
    local lock_dir="$1"

    rm -f "$lock_dir/pid" 2>/dev/null
    rmdir "$lock_dir" 2>/dev/null
}

mark_pending_reload() {
    local reason="${1:-pending}"
    local now

    ensure_runtime_dirs
    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    {
        printf 'reason=%s\n' "$reason"
        printf 'updated_at=%s\n' "$now"
    } > "$PODKOP_PENDING_RELOAD_FILE"
}

consume_pending_reload() {
    [ -f "$PODKOP_PENDING_RELOAD_FILE" ] || return 1
    rm -f "$PODKOP_PENDING_RELOAD_FILE" 2>/dev/null
}

run_pending_reload_if_requested() {
    consume_pending_reload || return 0
    echolog "Applying pending Podkop reload"
    "$PODKOP_SERVICE_INIT" reload pending >/dev/null 2>&1 &
}

sync_time_if_needed() {
    local current_year

    current_year="$(date +%Y 2>/dev/null)"
    case "$current_year" in
    '' | *[!0-9]*)
        return 0
        ;;
    esac

    [ "$current_year" -lt 2024 ] || return 0

    /usr/sbin/ntpd -q -p 194.190.168.1 -p 216.239.35.0 -p 216.239.35.4 -p 162.159.200.1 -p 162.159.200.123 >/dev/null 2>&1 || true
}

process_age_seconds() {
    local pid="$1"
    local stat stat_rest start_ticks uptime_seconds

    [ -r "/proc/$pid/stat" ] || return 1

    stat="$(cat "/proc/$pid/stat" 2>/dev/null)" || return 1
    stat_rest="${stat##*) }"

    set -- $stat_rest
    [ "$#" -ge 20 ] || return 1
    shift 19
    start_ticks="$1"

    case "$start_ticks" in
    '' | *[!0-9]*) return 1 ;;
    esac

    read -r uptime_seconds _ < /proc/uptime || return 1
    uptime_seconds="${uptime_seconds%%.*}"
    case "$uptime_seconds" in
    '' | *[!0-9]*) return 1 ;;
    esac

    echo $((uptime_seconds - (start_ticks / 100)))
}

sing_box_service_pid() {
    local service_json='{"name":"sing-box"}'

    ubus call service list "$service_json" 2>/dev/null |
        jq -r '.["sing-box"].instances // {} | to_entries[] | select((.value.running // false) == true and ((.value.pid // 0) > 0)) | .value.pid' 2>/dev/null |
        sed -n '1p'
}

pid_is_sing_box() {
    local pid="$1"
    local exe

    case "$pid" in
    '' | *[!0-9]*) return 1 ;;
    esac

    exe="$(readlink "/proc/$pid/exe" 2>/dev/null)" || return 1
    [ "${exe##*/}" = "sing-box" ]
}

sing_box_service_is_running() {
    local pid

    pid="$(sing_box_service_pid)"
    pid_is_sing_box "$pid"
}

sing_box_service_is_stable() {
    local min_age="${1:-$PODKOP_RUNTIME_STABLE_MIN_AGE}"
    local pid age

    pid="$(sing_box_service_pid)"
    pid_is_sing_box "$pid" || return 1

    age="$(process_age_seconds "$pid")" || return 1
    [ "$age" -ge "$min_age" ]
}

podkop_runtime_network_is_configured() {
    nft list table inet "$NFT_TABLE_NAME" >/dev/null 2>&1 &&
        ip rule list | grep -q "lookup $RT_TABLE_NAME" &&
        ip route list table "$RT_TABLE_NAME" 2>/dev/null | grep -q "local default dev lo scope host"
}

podkop_is_running() {
    sing_box_service_is_running &&
        podkop_runtime_network_is_configured
}

podkop_is_stably_running() {
    sing_box_service_is_stable &&
        podkop_runtime_network_is_configured
}

podkop_wait_until_stably_running() {
    local timeout="${1:-$PODKOP_RUNTIME_STABLE_WAIT_TIMEOUT}"
    local started_at now

    started_at="$(date +%s 2>/dev/null)"
    case "$started_at" in
    '' | *[!0-9]*) started_at=0 ;;
    esac

    while true; do
        podkop_is_stably_running && return 0

        now="$(date +%s 2>/dev/null)"
        case "$now" in
        '' | *[!0-9]*) now=0 ;;
        esac

        [ "$started_at" -gt 0 ] && [ "$now" -gt 0 ] && [ $((now - started_at)) -ge "$timeout" ] && return 1
        sleep 1
    done
}

runtime_status_action_expects_running() {
    case "$1" in
    start | restart | reload)
        return 0
        ;;
    esac

    return 1
}

runtime_status_restart_action_is_active() {
    [ "${PODKOP_LIFECYCLE_ACTION:-}" = "restart" ] || restart_intent_is_active
}

runtime_status_write() {
    local state="$1"
    local action="${2:-none}"
    local message="${3:-}"
    local now tmpfile

    ensure_runtime_dirs
    if runtime_status_restart_action_is_active; then
        case "$action" in
        start | stop | restart)
            action="restart"
            ;;
        esac

        case "$state" in
        starting | stopping | restarting)
            state="restarting"
            ;;
        stopped)
            [ "$action" = "restart" ] && state="restarting"
            ;;
        esac
    fi

    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    tmpfile="${PODKOP_RUNTIME_STATUS_FILE}.$$"
    {
        printf 'format=%s\n' "$PODKOP_RUNTIME_STATUS_FORMAT"
        printf 'state=%s\n' "$state"
        printf 'action=%s\n' "$action"
        printf 'updated_at=%s\n' "$now"
        printf 'pid=%s\n' "$$"
        printf 'message=%s\n' "$message"
    } > "$tmpfile" && mv "$tmpfile" "$PODKOP_RUNTIME_STATUS_FILE"
}

runtime_status_mark_failure() {
    local action="${1:-unknown}"

    if podkop_is_stably_running; then
        runtime_status_write "running" "$action"
    else
        runtime_status_write "failed" "$action" "operation did not complete"
    fi
}

runtime_status_finish_action() {
    local action="${1:-none}"
    local status="${2:-0}"

    trap - EXIT INT TERM

    if [ "$status" -eq 0 ]; then
        if runtime_status_action_expects_running "$action" && ! podkop_wait_until_stably_running; then
            runtime_status_write "failed" "$action" "runtime did not become ready"
            return 0
        fi

        if podkop_is_stably_running; then
            runtime_status_write "running" "$action"
        else
            runtime_status_write "stopped" "$action"
        fi
        return 0
    fi

    runtime_status_mark_failure "$action"
    return "$status"
}

runtime_status_read_value() {
    local key="$1"

    [ -f "$PODKOP_RUNTIME_STATUS_FILE" ] || return 1

    awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$PODKOP_RUNTIME_STATUS_FILE"
}

runtime_status_is_transition() {
    case "$1" in
    starting | stopping | restarting | reloading | updating_subscription)
        return 0
        ;;
    esac

    return 1
}

runtime_status_transition_is_active() {
    local state="$1"
    local updated_at="$2"
    local pid="$3"
    local now age

    runtime_status_is_transition "$state" || return 1

    case "$updated_at" in
    '' | *[!0-9]*) return 1 ;;
    esac

    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    case "$pid" in
    '' | *[!0-9]*)
        [ "$now" -gt 0 ] || return 0
        ;;
    *)
        if [ "$state" = "updating_subscription" ]; then
            kill -0 "$pid" 2>/dev/null
            return "$?"
        fi
        ;;
    esac

    [ "$now" -gt 0 ] || return 0
    age=$((now - updated_at))
    [ "$age" -ge 0 ] || return 1
    [ "$age" -le "$PODKOP_RUNTIME_TRANSITION_MAX_AGE" ] || return 1

    case "$pid" in
    '' | *[!0-9]*) return 0 ;;
    esac

    kill -0 "$pid" 2>/dev/null && return 0

    case "$state" in
    starting | stopping | restarting | reloading)
        [ "$age" -le "$PODKOP_RUNTIME_TRANSITION_DEAD_PID_GRACE" ] && return 0
        ;;
    esac

    return 1
}

restart_intent_is_active() {
    local now updated_at age

    [ -f "$PODKOP_RESTART_INTENT_FILE" ] || return 1

    updated_at="$(awk -F= '$1 == "updated_at" { print $2; exit }' "$PODKOP_RESTART_INTENT_FILE" 2>/dev/null)"
    case "$updated_at" in
    '' | *[!0-9]*)
        rm -f "$PODKOP_RESTART_INTENT_FILE" 2>/dev/null
        return 1
        ;;
    esac

    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) return 0 ;;
    esac

    age=$((now - updated_at))
    if [ "$age" -lt 0 ] || [ "$age" -gt "$PODKOP_RUNTIME_TRANSITION_MAX_AGE" ]; then
        rm -f "$PODKOP_RESTART_INTENT_FILE" 2>/dev/null
        return 1
    fi

    return 0
}

clear_reload_state() {
    rm -f "$PODKOP_RELOAD_STATE_FILE"
}

read_reload_state_value() {
    local key="$1"

    [ -f "$PODKOP_RELOAD_STATE_FILE" ] || return 1

    awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$PODKOP_RELOAD_STATE_FILE"
}

reload_state_is_compatible() {
    [ "$(read_reload_state_value "format")" = "$PODKOP_RELOAD_STATE_FORMAT" ]
}

signature_begin() {
    RELOAD_SIGNATURE_TMPFILE="$(mktemp)"
}

signature_add() {
    local key="$1"
    local value="$2"

    printf '[%s]\n%s\n' "$key" "$value" >> "$RELOAD_SIGNATURE_TMPFILE"
}

signature_finish() {
    local hash

    hash="$(md5sum "$RELOAD_SIGNATURE_TMPFILE" | awk '{print $1}')"
    rm -f "$RELOAD_SIGNATURE_TMPFILE"
    echo "$hash"
}

build_service_trigger_signature() {
    # These settings are consumed by init.d/procd triggers, not by sing-box/nft
    # runtime. Track them separately so config reloads can refresh procd without
    # forcing an in-process runtime restart.
    local enable_badwan_interface_monitoring badwan_monitored_interfaces badwan_reload_delay

    signature_begin
    config_get_bool enable_badwan_interface_monitoring "settings" "enable_badwan_interface_monitoring" 0
    signature_add "settings.enable_badwan_interface_monitoring" "$enable_badwan_interface_monitoring"

    if [ "$enable_badwan_interface_monitoring" -eq 1 ]; then
        config_get badwan_monitored_interfaces "settings" "badwan_monitored_interfaces"
        config_get badwan_reload_delay "settings" "badwan_reload_delay" "2000"
        signature_add "settings.badwan_monitored_interfaces" "$badwan_monitored_interfaces"
        signature_add "settings.badwan_reload_delay" "$badwan_reload_delay"
    fi

    signature_finish
}

build_dnsmasq_signature() {
    local dont_touch_dhcp source_network_interfaces

    signature_begin
    config_get_bool dont_touch_dhcp "settings" "dont_touch_dhcp" 0
    config_get source_network_interfaces "settings" "source_network_interfaces" "br-lan"
    signature_add "settings.dont_touch_dhcp" "$dont_touch_dhcp"
    signature_add "settings.source_network_interfaces" "$source_network_interfaces"
    signature_finish
}

append_sing_box_rule_signature() {
    local section="$1"
    local action proxy_config_type domain domain_suffix domain_keyword domain_regex ip_cidr source_ip_cidr \
        community_lists rule_set rule_set_with_subnets domain_ip_lists mixed_proxy_enabled mixed_proxy_port resolve_real_ip_for_routing

    rule_is_enabled "$section" || return 0

    action="$(get_rule_action "$section")"
    [ -n "$action" ] || return 0

    signature_add "rule.$section.action" "$action"

    case "$action" in
    proxy)
        proxy_config_type="$(get_proxy_config_type "$section")"
        signature_add "rule.$section.proxy_config_type" "$proxy_config_type"
        case "$proxy_config_type" in
        url)
            local proxy_string udp_over_tcp
            config_get proxy_string "$section" "proxy_string"
            config_get_bool udp_over_tcp "$section" "enable_udp_over_tcp" 0
            signature_add "rule.$section.proxy_string" "$proxy_string"
            signature_add "rule.$section.enable_udp_over_tcp" "$udp_over_tcp"
            ;;
        outbound)
            local outbound_json
            config_get outbound_json "$section" "outbound_json"
            signature_add "rule.$section.outbound_json" "$outbound_json"
            ;;
        selector)
            local selector_proxy_links udp_over_tcp
            config_get selector_proxy_links "$section" "selector_proxy_links"
            config_get_bool udp_over_tcp "$section" "enable_udp_over_tcp" 0
            signature_add "rule.$section.selector_proxy_links" "$selector_proxy_links"
            signature_add "rule.$section.enable_udp_over_tcp" "$udp_over_tcp"
            ;;
        urltest)
            local urltest_proxy_links udp_over_tcp urltest_check_interval urltest_tolerance urltest_testing_url
            config_get urltest_proxy_links "$section" "urltest_proxy_links"
            config_get_bool udp_over_tcp "$section" "enable_udp_over_tcp" 0
            urltest_check_interval="$(get_urltest_check_interval_for_rule "$section")"
            config_get urltest_tolerance "$section" "urltest_tolerance" 50
            config_get urltest_testing_url "$section" "urltest_testing_url" "https://www.gstatic.com/generate_204"
            signature_add "rule.$section.urltest_proxy_links" "$urltest_proxy_links"
            signature_add "rule.$section.enable_udp_over_tcp" "$udp_over_tcp"
            signature_add "rule.$section.urltest_check_interval" "$urltest_check_interval"
            signature_add "rule.$section.urltest_tolerance" "$urltest_tolerance"
            signature_add "rule.$section.urltest_testing_url" "$urltest_testing_url"
            ;;
        subscription)
            local subscription_url subscription_user_agent subscription_group_by_countries \
                urltest_check_interval urltest_tolerance urltest_testing_url
            config_get subscription_url "$section" "subscription_url"
            config_get subscription_user_agent "$section" "subscription_user_agent" ""
            config_get subscription_group_by_countries "$section" "subscription_group_by_countries"
            urltest_check_interval="$(get_urltest_check_interval_for_rule "$section")"
            config_get urltest_tolerance "$section" "urltest_tolerance" 50
            config_get urltest_testing_url "$section" "urltest_testing_url" "https://www.gstatic.com/generate_204"
            signature_add "rule.$section.subscription_url" "$subscription_url"
            signature_add "rule.$section.subscription_user_agent" "$subscription_user_agent"
            signature_add "rule.$section.subscription_group_by_countries" "$subscription_group_by_countries"
            signature_add "rule.$section.urltest_check_interval" "$urltest_check_interval"
            signature_add "rule.$section.urltest_tolerance" "$urltest_tolerance"
            signature_add "rule.$section.urltest_testing_url" "$urltest_testing_url"
            ;;
        esac

        config_get_bool mixed_proxy_enabled "$section" "mixed_proxy_enabled" 0
        signature_add "rule.$section.mixed_proxy_enabled" "$mixed_proxy_enabled"
        if [ "$mixed_proxy_enabled" -eq 1 ]; then
            config_get mixed_proxy_port "$section" "mixed_proxy_port"
            signature_add "rule.$section.mixed_proxy_port" "$mixed_proxy_port"
        fi

        config_get_bool resolve_real_ip_for_routing "$section" "resolve_real_ip_for_routing" 0
        signature_add "rule.$section.resolve_real_ip_for_routing" "$resolve_real_ip_for_routing"
        ;;
    vpn)
        local interface_name domain_resolver_enabled domain_resolver_dns_type domain_resolver_dns_server
        config_get interface_name "$section" "interface"
        config_get_bool domain_resolver_enabled "$section" "domain_resolver_enabled" 0
        signature_add "rule.$section.interface" "$interface_name"
        signature_add "rule.$section.domain_resolver_enabled" "$domain_resolver_enabled"
        if [ "$domain_resolver_enabled" -eq 1 ]; then
            config_get domain_resolver_dns_type "$section" "domain_resolver_dns_type"
            config_get domain_resolver_dns_server "$section" "domain_resolver_dns_server"
            signature_add "rule.$section.domain_resolver_dns_type" "$domain_resolver_dns_type"
            signature_add "rule.$section.domain_resolver_dns_server" "$domain_resolver_dns_server"
        fi

        config_get_bool mixed_proxy_enabled "$section" "mixed_proxy_enabled" 0
        signature_add "rule.$section.mixed_proxy_enabled" "$mixed_proxy_enabled"
        if [ "$mixed_proxy_enabled" -eq 1 ]; then
            config_get mixed_proxy_port "$section" "mixed_proxy_port"
            signature_add "rule.$section.mixed_proxy_port" "$mixed_proxy_port"
        fi

        config_get_bool resolve_real_ip_for_routing "$section" "resolve_real_ip_for_routing" 0
        signature_add "rule.$section.resolve_real_ip_for_routing" "$resolve_real_ip_for_routing"
        ;;
    esac

    domain="$(get_rule_condition_commas_string "$section" "domain" "domains")"
    domain_suffix="$(get_rule_condition_commas_string "$section" "domain_suffix" "domains")"
    domain_keyword="$(get_rule_condition_commas_string "$section" "domain_keyword" "generic")"
    domain_regex="$(get_rule_condition_commas_string "$section" "domain_regex" "generic")"
    ip_cidr="$(get_rule_condition_commas_string "$section" "ip_cidr" "subnets")"
    source_ip_cidr="$(get_rule_condition_commas_string "$section" "source_ip_cidr" "subnets")"
    config_get community_lists "$section" "community_lists"
    config_get rule_set "$section" "rule_set"
    config_get rule_set_with_subnets "$section" "rule_set_with_subnets"
    config_get domain_ip_lists "$section" "domain_ip_lists"

    signature_add "rule.$section.domain" "$domain"
    signature_add "rule.$section.domain_suffix" "$domain_suffix"
    signature_add "rule.$section.domain_keyword" "$domain_keyword"
    signature_add "rule.$section.domain_regex" "$domain_regex"
    signature_add "rule.$section.ip_cidr" "$ip_cidr"
    signature_add "rule.$section.source_ip_cidr" "$source_ip_cidr"
    signature_add "rule.$section.community_lists" "$community_lists"
    signature_add "rule.$section.rule_set" "$rule_set"
    signature_add "rule.$section.rule_set_with_subnets" "$rule_set_with_subnets"
    signature_add "rule.$section.domain_ip_lists" "$domain_ip_lists"
}

build_sing_box_signature() {
    local dns_type dns_server bootstrap_dns_server rewrite_ttl output_network_interface disable_quic routing_excluded_ips \
        update_interval cache_path config_path log_level enable_yacd enable_yacd_wan_access yacd_secret_key \
        download_lists_via_proxy download_lists_via_proxy_section service_listen_address

    signature_begin

    config_get dns_type "settings" "dns_type" "doh"
    config_get dns_server "settings" "dns_server" "1.1.1.1"
    config_get bootstrap_dns_server "settings" "bootstrap_dns_server" "77.88.8.8"
    config_get rewrite_ttl "settings" "dns_rewrite_ttl" "60"
    config_get output_network_interface "settings" "output_network_interface"
    config_get_bool disable_quic "settings" "disable_quic" 0
    config_get routing_excluded_ips "settings" "routing_excluded_ips"
    config_get update_interval "settings" "update_interval"
    config_get cache_path "settings" "cache_path" "/tmp/sing-box/cache.db"
    config_get config_path "settings" "config_path"
    config_get log_level "settings" "log_level" "warn"
    config_get service_listen_address "settings" "service_listen_address"
    config_get_bool enable_yacd "settings" "enable_yacd" 0
    config_get_bool enable_yacd_wan_access "settings" "enable_yacd_wan_access" 0
    config_get_bool download_lists_via_proxy "settings" "download_lists_via_proxy" 0

    signature_add "settings.dns_type" "$dns_type"
    signature_add "settings.dns_server" "$dns_server"
    signature_add "settings.bootstrap_dns_server" "$bootstrap_dns_server"
    signature_add "settings.dns_rewrite_ttl" "$rewrite_ttl"
    signature_add "settings.output_network_interface" "$output_network_interface"
    signature_add "settings.disable_quic" "$disable_quic"
    signature_add "settings.routing_excluded_ips" "$routing_excluded_ips"
    if has_remote_sing_box_ruleset_sources; then
        signature_add "settings.update_interval" "$update_interval"
    fi
    signature_add "settings.cache_path" "$cache_path"
    signature_add "settings.config_path" "$config_path"
    signature_add "settings.log_level" "$log_level"
    signature_add "settings.service_listen_address" "$service_listen_address"
    signature_add "settings.enable_yacd" "$enable_yacd"
    if [ "$enable_yacd" -eq 1 ]; then
        signature_add "settings.enable_yacd_wan_access" "$enable_yacd_wan_access"
        config_get yacd_secret_key "settings" "yacd_secret_key"
        signature_add "settings.yacd_secret_key" "$yacd_secret_key"
    fi

    signature_add "settings.download_lists_via_proxy" "$download_lists_via_proxy"
    if [ "$download_lists_via_proxy" -eq 1 ]; then
        config_get download_lists_via_proxy_section "settings" "download_lists_via_proxy_section"
        signature_add "settings.download_lists_via_proxy_section" "$download_lists_via_proxy_section"
    fi

    config_foreach append_sing_box_rule_signature "rule"
    signature_finish
}

