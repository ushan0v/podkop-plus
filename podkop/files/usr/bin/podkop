get_sing_box_status() {
    local running=0
    local enabled=0
    local status=""
    local version=""
    local dns_configured=0

    # Check if service is enabled
    if [ -x /etc/rc.d/S99sing-box ]; then
        enabled=1
    fi

    # Check if service is running
    if pgrep -f "sing-box" > /dev/null; then
        running=1
        version=$(sing-box version | head -n 1 | awk '{print $3}')
    fi

    # Check DNS configuration
    if dnsmasq_has_podkop_dns; then
        dns_configured=1
    fi

    # Format status message
    if [ $running -eq 1 ]; then
        if [ $enabled -eq 1 ]; then
            status="running & enabled"
        else
            status="running but disabled"
        fi
    else
        if [ $enabled -eq 1 ]; then
            status="stopped but enabled"
        else
            status="stopped & disabled"
        fi
    fi

    echo "{\"running\":$running,\"enabled\":$enabled,\"status\":\"$status\",\"dns_configured\":$dns_configured}"
}

get_status() {
    local running=0
    local enabled=0
    local status=""
    local dns_configured=0

    if podkop_is_running; then
        running=1
    fi

    # Check if service is enabled
    if [ -x "/etc/rc.d/S99$PODKOP_SERVICE_NAME" ]; then
        enabled=1
    fi

    if dnsmasq_has_podkop_dns; then
        dns_configured=1
    fi

    if [ "$running" -eq 1 ]; then
        if [ "$enabled" -eq 1 ]; then
            status="running & enabled"
        else
            status="running but disabled"
        fi
    else
        if [ "$enabled" -eq 1 ]; then
            status="stopped but enabled"
        else
            status="stopped & disabled"
        fi
    fi

    json_utils_ucode object-json \
        running n "$running" \
        enabled n "$enabled" \
        status s "$status" \
        dns_configured n "$dns_configured"
}

get_outbound_link() {
    local section="$1"
    local outbound_tag="$2"

    ensure_runtime_dirs
    case "$section" in
    "" | */* | *..*)
        printf '{"link":""}\n'
        return 0
        ;;
    esac

    subscription_cache_ucode get-link \
        "$PODKOP_SECTION_CACHE_DIR" "$TMP_SUBSCRIPTION_FOLDER" "$section" "$outbound_tag" "$PODKOP_SUBSCRIPTION_LINKS_DIR" ||
        printf '{"link":""}\n'
}

get_outbound_link_states() {
    local section="$1"

    ensure_runtime_dirs
    case "$section" in
    "" | */* | *..*)
        printf '{}\n'
        return 0
        ;;
    esac

    subscription_cache_ucode get-link-states "$PODKOP_SECTION_CACHE_DIR" "$section" "$PODKOP_SUBSCRIPTION_LINKS_DIR" ||
        printf '{}\n'
}

get_outbound_metadata() {
    local section="$1"
    local metadata_path

    ensure_runtime_dirs
    case "$section" in
    "" | */* | *..*)
        printf '{"names":{},"countries":{}}\n'
        return 0
        ;;
    esac

    metadata_path="$(get_outbound_metadata_path "$section")"
    subscription_cache_ucode get-outbound-metadata "$PODKOP_SECTION_CACHE_DIR" "$section" "$metadata_path" ||
        printf '{"names":{},"countries":{}}\n'
}

get_subscription_metadata() {
    local section="$1"
    local metadata_path

    ensure_runtime_dirs

    case "$section" in
    "" | */* | *..*)
        printf '{}\n'
        return 0
        ;;
    esac

    metadata_path="$(get_subscription_metadata_path "$section")"
    subscription_cache_ucode get-subscription-metadata "$PODKOP_SECTION_CACHE_DIR" "$section" "$metadata_path" ||
        printf '{}\n'
}

validate_nfqws_strategy_json() {
    local raw_opt="${1:-}"

    if check_nfqws_strategy "$raw_opt"; then
        json_utils_ucode nfqws-strategy-validation true "" "" ""
        return 0
    fi

    json_utils_ucode nfqws-strategy-validation false "$NFQWS_VALIDATE_ERROR" "$NFQWS_VALIDATE_NEEDLE" "$NFQWS_VALIDATE_NEEDLES"
}

dns_check_resolve_host() {
    local host="$1"
    local resolver="$2"
    local resolved

    [ -n "$host" ] || return 1

    if is_ipv4 "$host"; then
        printf '%s\n' "$host"
        return 0
    fi

    [ -n "$resolver" ] || return 1

    resolved="$(
        dig @"$resolver" "$host" A +short +timeout=2 +tries=1 2> /dev/null |
            awk '/^[0-9]+\./ { print; exit }'
    )"
    [ -n "$resolved" ] || return 1

    printf '%s\n' "$resolved"
}

dns_check_dig_server_available() {
    local dns_type="$1"
    local dns_server="$2"
    local bootstrap_dns_server="$3"
    local domain="$4"
    local dns_host server_port probe_server tls_hostname

    dns_host="$(url_get_host "$dns_server")"
    [ -n "$dns_host" ] || dns_host="$dns_server"
    server_port="$(url_get_port "$dns_server")"
    tls_hostname=""

    if is_ipv4 "$dns_host"; then
        probe_server="$dns_host"
    else
        probe_server="$(dns_check_resolve_host "$dns_host" "$bootstrap_dns_server")"
        [ -n "$probe_server" ] || return 1
        tls_hostname="$dns_host"
    fi

    case "$dns_type" in
    dot)
        if [ -n "$tls_hostname" ]; then
            if [ -n "$server_port" ]; then
                dig -p "$server_port" @"$probe_server" "$domain" +tls +tls-hostname="$tls_hostname" +timeout=2 +tries=1 > /dev/null 2>&1
            else
                dig @"$probe_server" "$domain" +tls +tls-hostname="$tls_hostname" +timeout=2 +tries=1 > /dev/null 2>&1
            fi
        else
            if [ -n "$server_port" ]; then
                dig -p "$server_port" @"$probe_server" "$domain" +tls +timeout=2 +tries=1 > /dev/null 2>&1
            else
                dig @"$probe_server" "$domain" +tls +timeout=2 +tries=1 > /dev/null 2>&1
            fi
        fi
        ;;
    udp)
        if [ -n "$server_port" ]; then
            dig -p "$server_port" @"$probe_server" "$domain" +timeout=2 +tries=1 > /dev/null 2>&1
        else
            dig @"$probe_server" "$domain" +timeout=2 +tries=1 > /dev/null 2>&1
        fi
        ;;
    *)
        return 1
        ;;
    esac
}

dns_check_doh_server_available() {
    local dns_server="$1"
    local bootstrap_dns_server="$2"
    local dns_host server_port doh_path doh_query url http_code resolved_ip

    dns_host="$(url_get_host "$dns_server")"
    [ -n "$dns_host" ] || dns_host="$dns_server"
    [ -n "$dns_host" ] || return 1

    server_port="$(url_get_port "$dns_server")"
    [ -n "$server_port" ] || server_port=443

    doh_path="$(url_get_path "$dns_server")"
    [ -n "$doh_path" ] && [ "$doh_path" != "/" ] || doh_path="/dns-query"

    doh_query="AAABAAABAAAAAAAABmdvb2dsZQNjb20AAAEAAQ"
    url="https://$dns_host:$server_port$doh_path?dns=$doh_query"

    if is_ipv4 "$dns_host"; then
        http_code="$(curl -sS --max-time 3 -o /dev/null -w "%{http_code}" \
            -H "accept: application/dns-message" "$url" 2> /dev/null)"
    else
        resolved_ip="$(dns_check_resolve_host "$dns_host" "$bootstrap_dns_server")"
        [ -n "$resolved_ip" ] || return 1

        http_code="$(curl -sS --max-time 3 -o /dev/null -w "%{http_code}" \
            --resolve "$dns_host:$server_port:$resolved_ip" \
            -H "accept: application/dns-message" "$url" 2> /dev/null)"
    fi

    [ "$http_code" = "200" ]
}

dns_check_router_resolver_available() {
    local domain="$1"
    local address interface source_network_interfaces

    for address in 127.0.0.1 "$SB_DNS_INBOUND_ADDRESS"; do
        [ -n "$address" ] || continue
        if dig @"$address" "$domain" +timeout=2 +tries=1 > /dev/null 2>&1; then
            return 0
        fi
    done

    address="$(get_service_listen_address 2> /dev/null | head -n 1)"
    if [ -n "$address" ] &&
        dig @"$address" "$domain" +timeout=2 +tries=1 > /dev/null 2>&1; then
        return 0
    fi

    source_network_interfaces="$(uci_get "$PODKOP_CONFIG_NAME" "settings" "source_network_interfaces")"
    [ -n "$source_network_interfaces" ] || source_network_interfaces="br-lan"

    for interface in $source_network_interfaces; do
        network_get_ipaddr address "$interface"
        if [ -n "$address" ] &&
            dig @"$address" "$domain" +timeout=2 +tries=1 > /dev/null 2>&1; then
            return 0
        fi

        address="$(get_device_ipv4_address "$interface")"
        if [ -n "$address" ] &&
            dig @"$address" "$domain" +timeout=2 +tries=1 > /dev/null 2>&1; then
            return 0
        fi
    done

    return 1
}

check_dns_available() {
    local dns_type dns_server bootstrap_dns_server dns_server_host bootstrap_check_domain
    config_get dns_type "settings" "dns_type"
    config_get dns_server "settings" "dns_server"
    config_get bootstrap_dns_server "settings" "bootstrap_dns_server"

    local dns_status=0
    local dns_on_router=0
    local bootstrap_dns_status=0
    local dhcp_config_status=1
    local domain="google.com"

    # Mask NextDNS ID if present
    local display_dns_server="$dns_server"
    if echo "$dns_server" | grep -q "\.dns\.nextdns\.io$"; then
        local nextdns_id
        nextdns_id=$(echo "$dns_server" | cut -d'.' -f1)
        display_dns_server="$(echo "$nextdns_id" | sed 's/./*/g').dns.nextdns.io"
    elif echo "$dns_server" | grep -q "^dns\.nextdns\.io/"; then
        local masked_path
        masked_path=$(echo "$dns_server" | cut -d'/' -f2- | sed 's/./*/g')
        display_dns_server="dns.nextdns.io/$masked_path"
    fi

    dns_server_host="$(url_get_host "$dns_server")"
    [ -n "$dns_server_host" ] || dns_server_host="$dns_server"

    case "$dns_type" in
    doh)
        if dns_check_doh_server_available "$dns_server" "$bootstrap_dns_server"; then
            dns_status=1
        fi
        ;;
    dot | udp)
        if dns_check_dig_server_available "$dns_type" "$dns_server" "$bootstrap_dns_server" "$domain"; then
            dns_status=1
        fi
        ;;
    esac

    # Check if local DNS resolver is working
    if dns_check_router_resolver_available "$domain"; then
        dns_on_router=1
    fi

    # Check bootstrap DNS server
    if [ -n "$bootstrap_dns_server" ]; then
        bootstrap_check_domain="$domain"
        if [ -n "$dns_server_host" ] && ! is_ipv4 "$dns_server_host"; then
            bootstrap_check_domain="$dns_server_host"
        fi

        if dns_check_resolve_host "$bootstrap_check_domain" "$bootstrap_dns_server" > /dev/null; then
            bootstrap_dns_status=1
        fi
    fi

    # Check if dnsmasq sends DNS requests through Podkop DNS.
    config_load dhcp
    check_dhcp_has_podkop_dns
    config_load "$PODKOP_CONFIG_NAME"

    json_utils_ucode object-json \
        dns_type s "$dns_type" \
        dns_server s "$display_dns_server" \
        dns_status n "$dns_status" \
        dns_on_router n "$dns_on_router" \
        bootstrap_dns_server s "$bootstrap_dns_server" \
        bootstrap_dns_status n "$bootstrap_dns_status" \
        dhcp_config_status n "$dhcp_config_status"
}

check_dhcp_has_podkop_dns() {
    if ! dnsmasq_default_config_is_complete; then
        dhcp_config_status=0
    fi
}

check_nft_rules() {
    local table_exist=0
    local rules_mangle_exist=0
    local rules_mangle_counters=0
    local rules_mangle_output_exist=0
    local rules_mangle_output_counters=0
    local rules_proxy_exist=0
    local rules_proxy_counters=0
    local rules_other_mark_exist=0

    # Generate traffic through PodkopTable
    curl -m 3 -s "https://$CHECK_PROXY_IP_DOMAIN/check" > /dev/null 2>&1 &
    local pid1=$!
    curl -m 3 -s "https://$FAKEIP_TEST_DOMAIN/check" > /dev/null 2>&1 &
    local pid2=$!

    wait $pid1 2> /dev/null
    wait $pid2 2> /dev/null
    sleep 1

    # Check if PodkopPlusTable exists
    if nft list table inet "$NFT_TABLE_NAME" > /dev/null 2>&1; then
        table_exist=1

        # Check mangle chain rules
        if nft list chain inet "$NFT_TABLE_NAME" mangle > /dev/null 2>&1; then
            local mangle_output
            mangle_output=$(nft list chain inet "$NFT_TABLE_NAME" mangle)
            if echo "$mangle_output" | grep -q "counter"; then
                rules_mangle_exist=1

                if echo "$mangle_output" | grep "counter" | grep -qv "packets 0 bytes 0"; then
                    rules_mangle_counters=1
                fi
            fi
        fi

        # Check mangle_output chain rules
        if nft list chain inet "$NFT_TABLE_NAME" mangle_output > /dev/null 2>&1; then
            local mangle_output_output
            mangle_output_output=$(nft list chain inet "$NFT_TABLE_NAME" mangle_output)
            if echo "$mangle_output_output" | grep -q "counter"; then
                rules_mangle_output_exist=1

                if echo "$mangle_output_output" | grep "counter" | grep -qv "packets 0 bytes 0"; then
                    rules_mangle_output_counters=1
                fi
            fi
        fi

        # Check proxy chain rules
        if nft list chain inet "$NFT_TABLE_NAME" proxy > /dev/null 2>&1; then
            local proxy_output
            proxy_output=$(nft list chain inet "$NFT_TABLE_NAME" proxy)
            if echo "$proxy_output" | grep -q "counter"; then
                rules_proxy_exist=1

                if echo "$proxy_output" | grep "counter" | grep -qv "packets 0 bytes 0"; then
                    rules_proxy_counters=1
                fi
            fi
        fi
    fi

    # Check for other mark rules outside PodkopPlusTable
    nft list tables 2> /dev/null | while read -r _ family table_name; do
        [ -z "$table_name" ] && continue

        [ "$table_name" = "$NFT_TABLE_NAME" ] && continue

        if nft list table "$family" "$table_name" 2> /dev/null | grep -q "meta mark set"; then
            touch /tmp/podkop_mark_check.$$
            break
        fi
    done

    if [ -f /tmp/podkop_mark_check.$$ ]; then
        rules_other_mark_exist=1
        rm -f /tmp/podkop_mark_check.$$
    fi

    json_utils_ucode object-json \
        table_exist n "$table_exist" \
        rules_mangle_exist n "$rules_mangle_exist" \
        rules_mangle_counters n "$rules_mangle_counters" \
        rules_mangle_output_exist n "$rules_mangle_output_exist" \
        rules_mangle_output_counters n "$rules_mangle_output_counters" \
        rules_proxy_exist n "$rules_proxy_exist" \
        rules_proxy_counters n "$rules_proxy_counters" \
        rules_other_mark_exist n "$rules_other_mark_exist"
}

check_sing_box() {
    local sing_box_installed=0
    local sing_box_version_ok=0
    local sing_box_extended=0
    local sing_box_service_exist=0
    local sing_box_autostart_disabled=0
    local sing_box_process_running=0
    local sing_box_ports_listening=0

    # Check if sing-box is installed
    if command -v sing-box > /dev/null 2>&1; then
        sing_box_installed=1

        # Check version (must be >= 1.12.4)
        local version
        version=$(sing-box version 2> /dev/null | head -n 1 | awk '{print $NF}')
        if [ -n "$version" ]; then
            version=$(echo "$version" | sed 's/^v//')
            is_sing_box_extended "$version" && sing_box_extended=1

            if is_min_package_version "$version" "1.12.4"; then
                sing_box_version_ok=1
            fi
        fi
    fi

    # Check if service exists
    if [ -f /etc/init.d/sing-box ]; then
        sing_box_service_exist=1

        if ! /etc/init.d/sing-box enabled 2> /dev/null; then
            sing_box_autostart_disabled=1
        fi
    fi

    # Check if process is running
    if pgrep "sing-box" > /dev/null 2>&1; then
        sing_box_process_running=1
    fi

    # Check if sing-box is listening on required ports
    local port_53_ok=0
    local port_1602_ok=0

    if netstat -ln 2> /dev/null | grep -q "127.0.0.42:53"; then
        port_53_ok=1
    fi

    if netstat -ln 2> /dev/null | grep -q "127.0.0.1:1602"; then
        port_1602_ok=1
    fi

    # Both ports must be listening
    if [ "$port_53_ok" = "1" ] && [ "$port_1602_ok" = "1" ]; then
        sing_box_ports_listening=1
    fi

    json_utils_ucode object-json \
        sing_box_installed n "$sing_box_installed" \
        sing_box_version_ok n "$sing_box_version_ok" \
        sing_box_extended n "$sing_box_extended" \
        sing_box_service_exist n "$sing_box_service_exist" \
        sing_box_autostart_disabled n "$sing_box_autostart_disabled" \
        sing_box_process_running n "$sing_box_process_running" \
        sing_box_ports_listening n "$sing_box_ports_listening"
}

check_fakeip() {
    local fakeip_address fakeip_status

    fakeip_address="$(
        dig +short @"$SB_DNS_INBOUND_ADDRESS" "$FAKEIP_TEST_DOMAIN" A +timeout=2 +tries=1 2> /dev/null |
            awk '/^[0-9]+\./ { print; exit }'
    )"

    fakeip_status=false
    if echo "$fakeip_address" | grep -Eq "^198\.(18|19)\."; then
        fakeip_status=true
    fi

    json_utils_ucode object-json fakeip b "$fakeip_status" IP s "$fakeip_address"
}

#######################################
# Clash API interface for managing proxies and groups
# Arguments:
#   $1 - Action: get_proxies, get_connections, get_proxy_latency, get_group_latency, set_group_proxy,
#        close_connection, close_all_connections
#   $2 - Proxy/Group tag (required for latency and set operations) or connection id
#   $3 - Timeout in ms (optional, defaults: 2000 for proxy, 5000 for group) or target proxy tag for set_group_proxy
# Outputs:
#   JSON formatted response
# Usage:
#   clash_api get_proxies
#   clash_api get_connections
#   clash_api get_proxy_latency <proxy_tag> [timeout]
#   clash_api get_group_latency <group_tag> [timeout]
#   clash_api set_group_proxy <group_tag> <proxy_tag>
#   clash_api close_connection <connection_id>
#   clash_api close_all_connections
#######################################

clash_api_urlencode_path_segment() {
    json_utils_ucode url-encode "$1"
}

clash_api() {
    local action="$1"
    local clash_api_controller_address CLASH_URL TEST_URL
    clash_api_controller_address="$(get_service_listen_address)"
    if [ -z "$clash_api_controller_address" ]; then
        clash_api_controller_address="127.0.0.1"
    fi
    CLASH_URL="$clash_api_controller_address:$SB_CLASH_API_CONTROLLER_PORT"
    TEST_URL="https://www.gstatic.com/generate_204"

    local enable_yacd_wan_access yacd_secret_key auth_header
    config_get_bool enable_yacd_wan_access "settings" "enable_yacd_wan_access" 0
    config_get yacd_secret_key "settings" "yacd_secret_key"

    if [ "$enable_yacd_wan_access" -eq 1 ]; then
        auth_header="Authorization: Bearer $yacd_secret_key"
    else
        auth_header=""
    fi

    case "$action" in
    get_proxies)
        curl -s --header "$auth_header" "$CLASH_URL/proxies" | json_utils_ucode stdin-json
        ;;

    get_connections)
        curl -s --header "$auth_header" "$CLASH_URL/connections" | json_utils_ucode stdin-json
        ;;

    get_proxy_latency)
        local proxy_tag="$2"
        local timeout="${3:-2000}"

        if [ -z "$proxy_tag" ]; then
            json_utils_ucode object-json error s "proxy_tag required"
            return 1
        fi

        curl -G -s "$CLASH_URL/proxies/$proxy_tag/delay" \
            --header "$auth_header" \
            --data-urlencode "url=$TEST_URL" \
            --data-urlencode "timeout=$timeout" | json_utils_ucode stdin-json
        ;;

    get_group_latency)
        local group_tag="$2"
        local timeout="${3:-5000}"

        if [ -z "$group_tag" ]; then
            json_utils_ucode object-json error s "group_tag required"
            return 1
        fi

        curl -G -s "$CLASH_URL/group/$group_tag/delay" \
            --header "$auth_header" \
            --data-urlencode "url=$TEST_URL" \
            --data-urlencode "timeout=$timeout" | json_utils_ucode stdin-json
        ;;

    set_group_proxy)
        local group_tag="$2"
        local proxy_tag="$3"

        if [ -z "$group_tag" ] || [ -z "$proxy_tag" ]; then
            json_utils_ucode object-json error s "group_tag and proxy_tag required"
            return 1
        fi

        local response
        response=$(
            curl -X PUT -s -w "\n%{http_code}" "$CLASH_URL/proxies/$group_tag" \
                --header "$auth_header" \
                --data-raw "$(json_utils_ucode object-json name s "$proxy_tag")"
        )

        local http_code
        local body
        http_code=$(echo "$response" | tail -n 1)
        body=$(echo "$response" | sed '$d')

        case "$http_code" in
        204)
            json_utils_ucode object-json success b true group s "$group_tag" proxy s "$proxy_tag"
            ;;
        404)
            json_utils_ucode object-json success b false error s "group_not_found" message s "$group_tag does not exist"
            return 1
            ;;
        400)
            if echo "$body" | grep -q "not found"; then
                json_utils_ucode object-json success b false error s "proxy_not_found" message s "$proxy_tag not found in group $group_tag"
            else
                json_utils_ucode object-json success b false error s "bad_request" message s "Invalid request"
            fi
            return 1
            ;;
        *)
            if [ -n "$body" ]; then
                json_utils_ucode object-json success b false http_code n "$http_code" body a "$body"
            else
                json_utils_ucode object-json success b false http_code n "$http_code"
            fi
            return 1
            ;;
        esac
        ;;

    close_connection)
        local connection_id="$2"

        if [ -z "$connection_id" ]; then
            json_utils_ucode object-json error s "connection_id required"
            return 1
        fi

        local encoded_connection_id response http_code body
        encoded_connection_id="$(clash_api_urlencode_path_segment "$connection_id")" || return 1
        response=$(
            curl -X DELETE -s -w "\n%{http_code}" "$CLASH_URL/connections/$encoded_connection_id" \
                --header "$auth_header"
        )
        http_code=$(echo "$response" | tail -n 1)
        body=$(echo "$response" | sed '$d')

        case "$http_code" in
        200 | 204)
            json_utils_ucode object-json success b true connection_id s "$connection_id"
            ;;
        404)
            json_utils_ucode object-json success b false error s "connection_not_found" connection_id s "$connection_id"
            return 1
            ;;
        *)
            if [ -n "$body" ]; then
                json_utils_ucode object-json success b false http_code n "$http_code" body a "$body"
            else
                json_utils_ucode object-json success b false http_code n "$http_code"
            fi
            return 1
            ;;
        esac
        ;;

    close_all_connections)
        local response http_code body
        response=$(
            curl -X DELETE -s -w "\n%{http_code}" "$CLASH_URL/connections" \
                --header "$auth_header"
        )
        http_code=$(echo "$response" | tail -n 1)
        body=$(echo "$response" | sed '$d')

        case "$http_code" in
        200 | 204)
            json_utils_ucode object-json success b true
            ;;
        *)
            if [ -n "$body" ]; then
                json_utils_ucode object-json success b false http_code n "$http_code" body a "$body"
            else
                json_utils_ucode object-json success b false http_code n "$http_code"
            fi
            return 1
            ;;
        esac
        ;;

    *)
        json_utils_ucode object-json \
            error s "unknown action" \
            available j '["get_proxies","get_connections","get_proxy_latency","get_group_latency","set_group_proxy","close_connection","close_all_connections"]'
        return 1
        ;;
    esac
}

print_global() {
    local message="$1"
    echo "$message"
}

json_get_default() {
    local json="$1"
    local key="$2"
    local fallback="$3"

    printf '%s' "$json" | json_utils_ucode object-get-default "$key" "$fallback" 2>/dev/null
}

global_check() {
    local PODKOP_LUCI_VERSION="Unknown"
    [ -n "$1" ] && PODKOP_LUCI_VERSION="$1"

    print_global "📡 Global check run!"
    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "🛠️ System info"

    local system_info_json
    system_info_json=$(get_system_info)

    if [ -n "$system_info_json" ]; then
        local podkop_version podkop_latest_version luci_app_version sing_box_version sing_box_extended zapret_version zapret_installed byedpi_version byedpi_installed openwrt_version device_model

        podkop_version=$(json_get_default "$system_info_json" podkop_version "unknown")
        podkop_latest_version=$(json_get_default "$system_info_json" podkop_latest_version "unknown")
        luci_app_version=$(json_get_default "$system_info_json" luci_app_version "unknown")
        sing_box_version=$(json_get_default "$system_info_json" sing_box_version "unknown")
        sing_box_extended=$(json_get_default "$system_info_json" sing_box_extended 0)
        zapret_version=$(json_get_default "$system_info_json" zapret_version "unknown")
        zapret_installed=$(json_get_default "$system_info_json" zapret_installed 0)
        byedpi_version=$(json_get_default "$system_info_json" byedpi_version "unknown")
        byedpi_installed=$(json_get_default "$system_info_json" byedpi_installed 0)
        openwrt_version=$(json_get_default "$system_info_json" openwrt_version "unknown")
        device_model=$(json_get_default "$system_info_json" device_model "unknown")
        if [ "$sing_box_extended" -eq 1 ]; then
            print_global "Sing-box core: extended"
        else
            print_global "Sing-box core: regular"
        fi

        print_global "🕳️ Podkop Plus:   $podkop_version"
        print_global "🕳️ LuCI App:      $luci_app_version"
        print_global "📦 Sing-box:      $sing_box_version"
        if [ "$zapret_installed" -eq 1 ]; then
            print_global "🧵 Zapret:        $zapret_version"
        fi
        if [ "$byedpi_installed" -eq 1 ]; then
            print_global "🧵 ByeDPI:        $byedpi_version"
        fi
        print_global "🛜 OpenWrt:       $openwrt_version"
        print_global "🛜 Device:        $device_model"
    else
        print_global "❌ Failed to get system info"
    fi

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "➡️ DNS status"

    local dns_check_json
    dns_check_json=$(check_dns_available)

    if [ -n "$dns_check_json" ]; then
        local dns_type dns_server dns_status dns_on_router bootstrap_dns_server bootstrap_dns_status dhcp_config_status

        dns_type=$(json_get_default "$dns_check_json" dns_type "unknown")
        dns_server=$(json_get_default "$dns_check_json" dns_server "unknown")
        dns_status=$(json_get_default "$dns_check_json" dns_status 0)
        dns_on_router=$(json_get_default "$dns_check_json" dns_on_router 0)
        bootstrap_dns_server=$(json_get_default "$dns_check_json" bootstrap_dns_server "")
        bootstrap_dns_status=$(json_get_default "$dns_check_json" bootstrap_dns_status 0)
        dhcp_config_status=$(json_get_default "$dns_check_json" dhcp_config_status 0)

        # Bootstrap DNS
        if [ -n "$bootstrap_dns_server" ]; then
            if [ "$bootstrap_dns_status" -eq 1 ]; then
                print_global "✅ Bootstrap DNS: $bootstrap_dns_server"
            else
                print_global "❌ Bootstrap DNS: $bootstrap_dns_server"
            fi
        fi

        # DNS server status
        if [ "$dns_status" -eq 1 ]; then
            print_global "✅ Main DNS: $dns_server [$dns_type]"
        else
            print_global "❌ Main DNS: $dns_server [$dns_type]"
        fi

        # DNS on router
        if [ "$dns_on_router" -eq 1 ]; then
            print_global "✅ DNS on router"
        else
            print_global "❌ DNS on router"
        fi

        # DHCP configuration check
        local dont_touch_dhcp
        config_get dont_touch_dhcp "settings" "dont_touch_dhcp"

        if [ "$dont_touch_dhcp" = "1" ]; then
            print_global "⚠️ dont_touch_dhcp is enabled. 📄 DHCP config:"
            awk '/^config /{p=($2=="dnsmasq")} p' /etc/config/dhcp
        elif [ "$dhcp_config_status" -eq 0 ]; then
            print_global "❌ DHCP configuration differs from template. 📄 DHCP config:"
            awk '/^config /{p=($2=="dnsmasq")} p' /etc/config/dhcp
        else
            print_global "✅ /etc/config/dhcp"
        fi
    else
        print_global "❌ Failed to get DNS info"
    fi

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "📦 Sing-box status"

    local singbox_check_json
    singbox_check_json=$(check_sing_box)

    if [ -n "$singbox_check_json" ]; then
        local sing_box_installed sing_box_version_ok sing_box_extended sing_box_service_exist sing_box_autostart_disabled sing_box_process_running sing_box_ports_listening

        sing_box_installed=$(json_get_default "$singbox_check_json" sing_box_installed 0)
        sing_box_version_ok=$(json_get_default "$singbox_check_json" sing_box_version_ok 0)
        sing_box_extended=$(json_get_default "$singbox_check_json" sing_box_extended 0)
        sing_box_service_exist=$(json_get_default "$singbox_check_json" sing_box_service_exist 0)
        sing_box_autostart_disabled=$(json_get_default "$singbox_check_json" sing_box_autostart_disabled 0)
        sing_box_process_running=$(json_get_default "$singbox_check_json" sing_box_process_running 0)
        sing_box_ports_listening=$(json_get_default "$singbox_check_json" sing_box_ports_listening 0)

        if [ "$sing_box_installed" -eq 1 ]; then
            print_global "✅ Sing-box installed"
        else
            print_global "❌ Sing-box installed"
        fi

        if [ "$sing_box_version_ok" -eq 1 ]; then
            print_global "✅ Sing-box version is compatible (newer than 1.12.4)"
        else
            print_global "❌ Sing-box version is not compatible (older than 1.12.4)"
        fi

        if [ "$sing_box_extended" -eq 1 ]; then
            print_global "Sing-box extended detected"
        else
            print_global "Sing-box regular build detected"
        fi

        if [ "$sing_box_service_exist" -eq 1 ]; then
            print_global "✅ Sing-box service exist"
        else
            print_global "❌ Sing-box service exist"
        fi

        if [ "$sing_box_autostart_disabled" -eq 1 ]; then
            print_global "✅ Sing-box autostart disabled"
        else
            print_global "❌ Sing-box autostart disabled"
        fi

        if [ "$sing_box_process_running" -eq 1 ]; then
            print_global "✅ Sing-box process running"
        else
            print_global "❌ Sing-box process running"
        fi

        if [ "$sing_box_ports_listening" -eq 1 ]; then
            print_global "✅ Sing-box listening ports"
        else
            print_global "❌ Sing-box listening ports"
        fi
    else
        print_global "❌ Failed to get sing-box info"
    fi

    print_global "---------------------------"
    print_global "Inbounds checks"

    local inbounds_check_json
    inbounds_check_json=$(check_inbounds)

    if [ -n "$inbounds_check_json" ]; then
        local enabled_count wan_ip wan_public
        enabled_count=$(json_get_default "$inbounds_check_json" enabled_count 0)
        wan_ip=$(json_get_default "$inbounds_check_json" wan_ip "")
        wan_public=$(json_get_default "$inbounds_check_json" wan_public 0)

        if [ "$enabled_count" -eq 0 ]; then
            print_global "[OK] No enabled server inbounds"
        else
            if [ "$wan_public" -eq 1 ]; then
                print_global "[OK] WAN public IP: $wan_ip"
            elif [ -n "$wan_ip" ]; then
                print_global "[WARN] WAN IP is not public: $wan_ip"
            else
                print_global "[WARN] WAN IP was not detected"
            fi

            local inbounds_tmp index
            inbounds_tmp="$(mktemp)" || inbounds_tmp=""
            if [ -n "$inbounds_tmp" ] && printf '%s' "$inbounds_check_json" > "$inbounds_tmp"; then
                index=0
                while [ "$index" -lt "$enabled_count" ]; do
                    local label protocol listen listen_port public_host tag required_proto runtime_ok listening firewall_required firewall_open routes_configured public_host_resolved public_host_public public_host_matches_wan public_host_ips

                    label="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].label" 2>/dev/null)"
                    protocol="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].protocol" 2>/dev/null)"
                    listen="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].listen" 2>/dev/null)"
                    listen_port="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].listen_port" 2>/dev/null)"
                    public_host="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].public_host" 2>/dev/null)"
                    tag="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].tag" 2>/dev/null)"
                    required_proto="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].required_proto" 2>/dev/null)"
                    runtime_ok="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].runtime_ok" 2>/dev/null)"
                    listening="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].listening" 2>/dev/null)"
                    firewall_required="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].firewall_required" 2>/dev/null)"
                    firewall_open="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].firewall_open" 2>/dev/null)"
                    routes_configured="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].routes_configured" 2>/dev/null)"
                    public_host_resolved="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].public_host_resolved" 2>/dev/null)"
                    public_host_public="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].public_host_public" 2>/dev/null)"
                    public_host_matches_wan="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].public_host_matches_wan" 2>/dev/null)"
                    public_host_ips="$(jsonfilter -i "$inbounds_tmp" -e "@.items[$index].public_host_ips" 2>/dev/null)"

                    if [ "$runtime_ok" = "1" ]; then
                        print_global "[OK] $label: runtime $tag [$protocol]"
                    else
                        print_global "[FAIL] $label: generated inbound is missing or differs from UCI"
                    fi

                    if [ "$protocol" != "tailscale" ]; then
                        if [ "$listening" = "1" ]; then
                            print_global "[OK] $label: listening on $listen:$listen_port [$required_proto]"
                        else
                            print_global "[FAIL] $label: not listening on $listen:$listen_port [$required_proto]"
                        fi

                        if [ "$firewall_required" = "1" ]; then
                            if [ "$firewall_open" = "1" ]; then
                                print_global "[OK] $label: firewall accepts $required_proto/$listen_port from WAN"
                            else
                                print_global "[FAIL] $label: firewall does not accept $required_proto/$listen_port from WAN"
                            fi
                        else
                            print_global "[WARN] $label: firewall WAN check skipped for listen address $listen"
                        fi
                    else
                        print_global "[OK] $label: Tailscale endpoint does not need a public firewall port"
                    fi

                    if [ "$routes_configured" = "1" ]; then
                        print_global "[OK] $label: route rules for inbound exist"
                    else
                        print_global "[WARN] $label: route rules for inbound were not found"
                    fi

                    if [ "$protocol" != "tailscale" ]; then
                        if [ -n "$public_host" ]; then
                            if [ "$public_host_resolved" = "0" ]; then
                                print_global "[WARN] $label: public host does not resolve: $public_host"
                            elif [ "$public_host_public" = "0" ]; then
                                print_global "[WARN] $label: public host is not public: $public_host"
                            elif [ "$public_host_matches_wan" = "0" ]; then
                                print_global "[WARN] $label: public host resolves to $public_host_ips, WAN is $wan_ip"
                            else
                                print_global "[OK] $label: public host $public_host"
                            fi
                        else
                            print_global "[WARN] $label: public host is empty"
                        fi
                    fi

                    index=$((index + 1))
                done
            else
                print_global "[FAIL] Failed to parse inbounds check details"
            fi
            [ -z "$inbounds_tmp" ] || rm -f "$inbounds_tmp"
        fi
    else
        print_global "[FAIL] Failed to get inbounds info"
    fi

    local zapret_check_json
    zapret_check_json=$(check_zapret_runtime)

    if [ -n "$zapret_check_json" ] && [ "$(json_get_default "$zapret_check_json" zapret_installed 0)" = "1" ]; then
        print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        print_global "🧵 Zapret status"
        print_global "✅ Zapret provider available"
    fi

    local byedpi_check_json
    byedpi_check_json=$(check_byedpi_runtime)

    if [ -n "$byedpi_check_json" ] && [ "$(json_get_default "$byedpi_check_json" byedpi_installed 0)" = "1" ]; then
        print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        print_global "🧵 ByeDPI status"
        print_global "✅ ByeDPI provider available"
    fi

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "🧱 NFT rules status"

    local nft_check_json
    nft_check_json=$(check_nft_rules)

    if [ -n "$nft_check_json" ]; then
        local table_exist rules_mangle_exist rules_mangle_counters rules_mangle_output_exist rules_mangle_output_counters rules_proxy_exist rules_proxy_counters rules_other_mark_exist

        table_exist=$(json_get_default "$nft_check_json" table_exist 0)
        rules_mangle_exist=$(json_get_default "$nft_check_json" rules_mangle_exist 0)
        rules_mangle_counters=$(json_get_default "$nft_check_json" rules_mangle_counters 0)
        rules_mangle_output_exist=$(json_get_default "$nft_check_json" rules_mangle_output_exist 0)
        rules_mangle_output_counters=$(json_get_default "$nft_check_json" rules_mangle_output_counters 0)
        rules_proxy_exist=$(json_get_default "$nft_check_json" rules_proxy_exist 0)
        rules_proxy_counters=$(json_get_default "$nft_check_json" rules_proxy_counters 0)
        rules_other_mark_exist=$(json_get_default "$nft_check_json" rules_other_mark_exist 0)

        if [ "$table_exist" -eq 1 ]; then
            print_global "✅ Table exist"
        else
            print_global "❌ Table exist"
        fi

        if [ "$rules_mangle_exist" -eq 1 ]; then
            print_global "✅ Rules mangle exist"
        else
            print_global "❌ Rules mangle exist"
        fi

        if [ "$rules_mangle_counters" -eq 1 ]; then
            print_global "✅ Rules mangle counters"
        else
            print_global "⚠️  Rules mangle counters"
        fi

        if [ "$rules_mangle_output_exist" -eq 1 ]; then
            print_global "✅ Rules mangle output exist"
        else
            print_global "❌ Rules mangle output exist"
        fi

        if [ "$rules_mangle_output_counters" -eq 1 ]; then
            print_global "✅ Rules mangle output counters"
        else
            print_global "⚠️  Rules mangle output counters"
        fi

        if [ "$rules_proxy_exist" -eq 1 ]; then
            print_global "✅ Rules proxy exist"
        else
            print_global "❌ Rules proxy exist"
        fi

        if [ "$rules_proxy_counters" -eq 1 ]; then
            print_global "✅ Rules proxy counters"
        else
            print_global "⚠️  Rules proxy counters"
        fi

        if [ "$rules_other_mark_exist" -eq 1 ]; then
            print_global "⚠️  Additional marking rules found:"
            nft list ruleset | awk '/table inet '"$NFT_TABLE_NAME"'/{flag=1; next} /^table/{flag=0} !flag' | grep -E "mark set|meta mark"
        else
            print_global "✅ Additional marking rules found"
        fi
    else
        print_global "❌ Failed to get NFT rules info"
    fi

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "📄 Podkop Plus config"
    show_config

    # print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    # print_global "🔧 System check"

    # if grep -E "^nameserver\s+([0-9]{1,3}\.){3}[0-9]{1,3}" "$RESOLV_CONF" | grep -vqE "127\.0\.0\.1|0\.0\.0\.0"; then
    #     print_global "❌ /etc/resolv.conf contains external nameserver:"
    #     cat /etc/resolv.conf
    #     echo ""
    # else
    #     print_global "✅ /etc/resolv.conf"
    # fi

    # print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    # print_global "🧱 NFT table"
    # check_nft

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "📄 WAN config"
    if uci show network.wan > /dev/null 2>&1; then
        awk '
            /^config / {
                p = ($2 == "interface" && $3 == "'\''wan'\''")
                proto = ""
            }
            p {
                if ($1 == "option" && $2 == "proto") {
                    proto = $3
                    print
                } else if (proto == "'\''static'\''" && $1 == "option" && ($2 == "ipaddr" || $2 == "netmask" || $2 == "gateway")) {
                    print "        option", $2, "'\''******'\''"
                } else if (proto == "'\''pppoe'\''" && $1 == "option" && ($2 == "username" || $2 == "password")) {
                    print "        option", $2, "'\''******'\''"
                } else {
                    print
                }
            }
        ' /etc/config/network
    else
        print_global "❌ WAN configuration not found"
    fi

    if uci show network | grep -q endpoint_host; then
        uci show network | grep endpoint_host | cut -d'=' -f2 | tr -d "'\" " | while read -r host; do
            if [ "$host" = "engage.cloudflareclient.com" ]; then
                print_global "⚠️ WARP detected: $host"
                continue
            fi

            ip_prefix=$(echo "$host" | cut -d'.' -f1,2)
            if echo "$CLOUDFLARE_OCTETS" | grep -wq "$ip_prefix"; then
                print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                print_global "⚠️ WARP detected: $host"
            fi
        done
    fi

    if uci show network | grep -q route_allowed_ips; then
        uci show network | grep "wireguard_.*\.route_allowed_ips='1'" | cut -d'.' -f1-2 | while read -r peer_section; do
            local allowed_ips
            allowed_ips=$(uci get "${peer_section}.allowed_ips" 2> /dev/null)

            if [ "$allowed_ips" = "0.0.0.0/0" ]; then
                print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                print_global "⚠️ WG Route allowed IP enabled with 0.0.0.0/0"
            fi
        done
    fi

    if [ -x /etc/init.d/zapret ] && /etc/init.d/zapret status >/dev/null 2>&1; then
        print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        print_global "⚠️ Standalone zapret service is active. Podkop Plus uses separate queues, but packet-level policy overlap is possible."
    elif [ -x /etc/init.d/zapret ] && /etc/init.d/zapret enabled >/dev/null 2>&1; then
        print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        print_global "⚠️ Standalone zapret autostart is enabled. Podkop Plus will not modify /etc/config/zapret."
    fi

    print_global "━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_global "🥸 FakeIP status"

    local fakeip_check_json
    fakeip_check_json=$(check_fakeip)

    if [ -n "$fakeip_check_json" ]; then
        local fakeip_status fakeip_address

        fakeip_status=$(json_get_default "$fakeip_check_json" fakeip false)
        fakeip_address=$(json_get_default "$fakeip_check_json" IP "")

        if [ "$fakeip_status" = "true" ]; then
            print_global "✅ Sing-box FakeIP DNS works: $fakeip_address"
        else
            print_global "❌ Sing-box FakeIP DNS does NOT work"
        fi
    else
        print_global "❌ Failed to get FakeIP info"
    fi
}

show_help() {
    cat << EOF
Usage: $0 COMMAND

Available commands:
    start                   Start Podkop Plus service
    stop                    Stop Podkop Plus service
    reload                  Reload Podkop Plus configuration
    restart                 Restart Podkop Plus service
    enable                  Enable Podkop Plus autostart
    disable                 Disable Podkop Plus autostart
    uninstall               Remove Podkop Plus files installed outside opkg/apk
    main                    Run main Podkop Plus process
    list_update             Update remote lists
    list_update_if_due      Update remote lists only when the configured interval has elapsed
    subscription_update [rule] [source_index]
                            Update all subscription proxies, one rule, or one source in a rule
    subscription_update_async [rule] [source_index]
                            Start forced subscription update in the background
    subscription_update_status [job_id]
                            Get background subscription update status
    subscription_update_if_due
                            Update subscription proxies only when per-rule intervals have elapsed
    check_proxy             Check proxy connectivity
    check_nft               Check NFT rules
    check_nft_rules         Check NFT rules status
    check_sing_box          Check sing-box installation and status
    check_inbounds_config   Check whether enabled server inbounds are configured
    check_inbounds          Check server inbounds from the Servers tab
    check_logs              Show Podkop Plus logs from system journal
    check_sing_box_logs     Show sing-box logs
    check_fakeip            Test sing-box FakeIP DNS
    check_zapret_runtime    Check external zapret provider state
    check_byedpi_runtime    Check external ByeDPI provider state
    neutralize_zapret_defaults
                            Compatibility no-op; Podkop Plus does not manage standalone zapret
    clash_api               Clash API interface for managing proxies and groups
    show_config             Display current Podkop Plus configuration
    show_version            Show Podkop Plus version
    show_sing_box_config    Show sing-box configuration
    show_sing_box_version   Show sing-box version
    get_status              Get Podkop Plus service status
    get_outbound_link       Get source proxy link for a generated outbound
    get_outbound_metadata   Get generated outbound display names and countries
    get_subscription_metadata
                            Get UI-only metadata for a subscription rule
    get_sing_box_status     Get sing-box service status
    get_zapret_status       Get zapret provider and Podkop Plus-managed nfqws status
    get_byedpi_status       Get ByeDPI provider and Podkop Plus-managed ciadpi status
    get_system_info         Get system information in JSON format
    get_server_capabilities Get server UI capabilities in JSON format
    get_ui_capabilities     Get lightweight UI capabilities in JSON format
    generate_reality_keypair
                            Generate a sing-box Reality key pair in JSON format
    component_action        Manage Podkop Plus, sing-box, zapret, and ByeDPI components
    component_action_async  Start a component action in the background
    component_action_status Get background component action status
    check_dns_available     Check DNS server availability
    global_check            Run global system check
    validate_nfqws_strategy_json
                            Validate an NFQWS strategy and print JSON result
    validate_byedpi_strategy_json
                            Validate a ByeDPI ciadpi strategy and print JSON result
EOF
}

case "$1" in
start)
    start
    ;;
stop)
    stop
    ;;
reload)
    reload "$2"
    ;;
restart)
    restart
    ;;
enable)
    "$PODKOP_SERVICE_INIT" enable
    ;;
disable)
    "$PODKOP_SERVICE_INIT" disable
    ;;
uninstall)
    uninstall
    ;;
dnsmasq_restore | restore_dnsmasq)
    dnsmasq_restore_fail_safe
    ;;
main)
    main
    ;;
list_update)
    list_update
    ;;
list_update_if_due)
    list_update_if_due
    ;;
subscription_update)
    subscription_update "$2" "$3"
    ;;
subscription_update_async)
    subscription_update_async "$2" "$3"
    ;;
subscription_update_status)
    subscription_update_status "$2"
    ;;
subscription_update_if_due)
    subscription_update_if_due
    ;;
check_proxy)
    check_proxy
    ;;
check_nft)
    check_nft
