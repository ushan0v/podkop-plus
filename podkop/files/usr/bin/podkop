    echo "=== OpenWrt Version ==="
    grep OPENWRT_RELEASE /etc/os-release | cut -d'"' -f2
    echo
    echo "=== Device Model ==="
    cat /tmp/sysinfo/model
}

fetch_latest_podkop_version() {
    local releases_file tag best_tag

    command -v curl >/dev/null 2>&1 || return 1

    if command -v jq >/dev/null 2>&1; then
        releases_file="$(mktemp)"
        if curl --connect-timeout 2 -m 5 -fsSL "https://api.github.com/repos/$PODKOP_RELEASE_REPO/releases?per_page=50" > "$releases_file" 2>/dev/null; then
            best_tag=""
            for tag in $(jq -r '.[] | select(((.draft // false) | not) and ((.prerelease // false) | not)) | .tag_name // empty' "$releases_file" 2>/dev/null); do
                is_podkop_release_version "$tag" || continue

                if [ -z "$best_tag" ] || [ "$(podkop_release_version_compare "$best_tag" "$tag" 2>/dev/null)" -lt 0 ]; then
                    best_tag="$tag"
                fi
            done

            rm -f "$releases_file"
            [ -n "$best_tag" ] && echo "$best_tag"
        else
            rm -f "$releases_file"
        fi
        return 0
    fi

    curl --connect-timeout 2 -m 5 -fsSL "https://api.github.com/repos/$PODKOP_RELEASE_REPO/releases/latest" 2>/dev/null |
        sed -n 's/^[[:space:]]*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' |
        head -n 1
}

normalize_podkop_release_version() {
    printf '%s\n' "$1" | sed 's/^v//;s/-r\([0-9][0-9]*\)$/-\1/'
}

is_podkop_release_version() {
    normalize_podkop_release_version "$1" | grep -Eq '^([0-9]+([.][0-9]+)*(-[0-9]+)?|[0-9]+([.][0-9]+){3})$'
}

podkop_release_version_parts() {
    local version release old_ifs

    version="$(normalize_podkop_release_version "$1")"
    release=0

    case "$version" in
    *-*)
        release="${version##*-}"
        version="${version%-*}"
        ;;
    *.*.*.*)
        release="${version##*.}"
        version="${version%.*}"
        ;;
    esac

    case "$version" in '' | *[!0-9.]* | .* | *.) return 1 ;; esac
    case "$release" in '' | *[!0-9]*) return 1 ;; esac

    old_ifs="$IFS"
    IFS='.'
    set -- $version
    IFS="$old_ifs"

    [ -n "$1" ] || return 1
    case "$1" in *[!0-9]*) return 1 ;; esac
    case "${2:-0}" in *[!0-9]*) return 1 ;; esac
    case "${3:-0}" in *[!0-9]*) return 1 ;; esac

    printf '%s %s %s %s\n' "$1" "${2:-0}" "${3:-0}" "$release"
}

podkop_release_version_compare() {
    local lhs_parts rhs_parts lhs_major lhs_minor lhs_patch lhs_release rhs_major rhs_minor rhs_patch rhs_release

    lhs_parts="$(podkop_release_version_parts "$1")" || return 1
    rhs_parts="$(podkop_release_version_parts "$2")" || return 1

    set -- $lhs_parts
    lhs_major="$1"
    lhs_minor="$2"
    lhs_patch="$3"
    lhs_release="$4"

    set -- $rhs_parts
    rhs_major="$1"
    rhs_minor="$2"
    rhs_patch="$3"
    rhs_release="$4"

    [ "$lhs_major" -lt "$rhs_major" ] && echo -1 && return 0
    [ "$lhs_major" -gt "$rhs_major" ] && echo 1 && return 0
    [ "$lhs_minor" -lt "$rhs_minor" ] && echo -1 && return 0
    [ "$lhs_minor" -gt "$rhs_minor" ] && echo 1 && return 0
    [ "$lhs_patch" -lt "$rhs_patch" ] && echo -1 && return 0
    [ "$lhs_patch" -gt "$rhs_patch" ] && echo 1 && return 0
    [ "$lhs_release" -lt "$rhs_release" ] && echo -1 && return 0
    [ "$lhs_release" -gt "$rhs_release" ] && echo 1 && return 0
    echo 0
}

podkop_latest_version_is_older_than_current() {
    local latest_version="$1"
    local compare_result

    is_podkop_release_version "$latest_version" || return 1
    is_podkop_release_version "$PODKOP_VERSION" || return 1

    compare_result="$(podkop_release_version_compare "$latest_version" "$PODKOP_VERSION")" || return 1
    [ "$compare_result" -lt 0 ]
}

podkop_latest_version_is_newer_than_current() {
    local latest_version="$1"
    local compare_result

    is_podkop_release_version "$latest_version" || return 1
    is_podkop_release_version "$PODKOP_VERSION" || return 1

    compare_result="$(podkop_release_version_compare "$latest_version" "$PODKOP_VERSION")" || return 1
    [ "$compare_result" -gt 0 ]
}

write_podkop_latest_version_cache() {
    local value="$1"
    local timestamp="$2"
    local cache_file="/tmp/podkop-plus.latest-version.cache"

    [ -n "$value" ] || return 0

    {
        printf '%s\n' "$value"
        printf '%s\n' "$timestamp"
    } > "$cache_file"
}

refresh_podkop_latest_version_cache() {
    local fetched_value now

    fetched_value="$(fetch_latest_podkop_version)"
    [ -n "$fetched_value" ] || return 0

    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    write_podkop_latest_version_cache "$fetched_value" "$now"
}

get_podkop_latest_version() {
    local cache_file="/tmp/podkop-plus.latest-version.cache"
    local cache_ttl=21600
    local now cache_value cache_timestamp cache_is_recent fetched_value

    now="$(date +%s 2>/dev/null)"
    cache_value="$(sed -n '1p' "$cache_file" 2>/dev/null)"
    cache_timestamp="$(sed -n '2p' "$cache_file" 2>/dev/null)"

    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    case "$cache_timestamp" in
    '' | *[!0-9]*) cache_timestamp=0 ;;
    esac

    cache_is_recent=0
    if [ -n "$cache_value" ] && [ "$now" -gt 0 ] &&
        [ $((now - cache_timestamp)) -lt "$cache_ttl" ]; then
        cache_is_recent=1
    fi

    if [ "$cache_is_recent" -eq 1 ] && podkop_latest_version_is_newer_than_current "$cache_value"; then
        echo "$cache_value"
        return 0
    fi

    fetched_value="$(fetch_latest_podkop_version)"
    if [ -n "$fetched_value" ]; then
        now="$(date +%s 2>/dev/null)"
        case "$now" in
        '' | *[!0-9]*) now=0 ;;
        esac

        write_podkop_latest_version_cache "$fetched_value" "$now"
        echo "$fetched_value"
        return 0
    fi

    if [ -n "$cache_value" ] && podkop_latest_version_is_newer_than_current "$cache_value"; then
        echo "$cache_value"
        return 0
    fi

    echo "unknown"
}

get_luci_app_version() {
    if [ -f "$PODKOP_LUCI_VIEW_DIR/main.js" ]; then
        grep 'var PODKOP_LUCI_APP_VERSION' "$PODKOP_LUCI_VIEW_DIR/main.js" | cut -d'"' -f2
        return 0
    fi

    echo "not installed"
}

system_info_cache_is_valid() {
    local now cached_at cached_latest luci_app_version

    [ -s "$PODKOP_SYSTEM_INFO_CACHE_FILE" ] || return 1
    jq -e . "$PODKOP_SYSTEM_INFO_CACHE_FILE" >/dev/null 2>&1 || return 1

    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    cached_at="$(jq -r '.generated_at // 0' "$PODKOP_SYSTEM_INFO_CACHE_FILE" 2>/dev/null)"
    case "$cached_at" in
    '' | *[!0-9]*) cached_at=0 ;;
    esac

    if [ "$now" -gt 0 ] && [ "$cached_at" -gt 0 ] &&
        [ $((now - cached_at)) -ge "$PODKOP_SYSTEM_INFO_CACHE_TTL" ]; then
        return 1
    fi

    luci_app_version="$(get_luci_app_version)"
    jq -e \
        --arg podkop_version "$PODKOP_VERSION" \
        --arg luci_app_version "$luci_app_version" \
        '.podkop_version == $podkop_version and .luci_app_version == $luci_app_version' \
        "$PODKOP_SYSTEM_INFO_CACHE_FILE" >/dev/null 2>&1 || return 1

    cached_latest="$(jq -r '.podkop_latest_version // "unknown"' "$PODKOP_SYSTEM_INFO_CACHE_FILE" 2>/dev/null)"
    [ "$cached_latest" = "unknown" ] && return 1
    podkop_latest_version_is_older_than_current "$cached_latest" && return 1
    podkop_latest_version_is_newer_than_current "$cached_latest" || return 1

    return 0
}

write_system_info_cache() {
    local tmpfile

    ensure_runtime_dirs

    tmpfile="${PODKOP_SYSTEM_INFO_CACHE_FILE}.$$"
    cat > "$tmpfile" && mv "$tmpfile" "$PODKOP_SYSTEM_INFO_CACHE_FILE"
}

build_system_info() {
    local podkop_version podkop_latest_version luci_app_version sing_box_version sing_box_extended zapret_version zapret_installed byedpi_version byedpi_installed openwrt_version device_model
    local generated_at

    podkop_version="$PODKOP_VERSION"

    podkop_latest_version="$(get_podkop_latest_version)"
    [ -n "$podkop_latest_version" ] || podkop_latest_version="unknown"

    luci_app_version="$(get_luci_app_version)"

    if command -v sing-box > /dev/null 2>&1; then
        sing_box_version=$(sing-box version 2> /dev/null | head -n 1 | awk '{print $NF}')
        [ -z "$sing_box_version" ] && sing_box_version="unknown"
    else
        sing_box_version="not installed"
    fi
    sing_box_extended=0
    is_sing_box_extended "$sing_box_version" && sing_box_extended=1

    zapret_installed=0
    if is_zapret_installed; then
        zapret_installed=1
        zapret_version="$(get_zapret_package_version)"
        [ -z "$zapret_version" ] && zapret_version="unknown"
    else
        zapret_version="not installed"
    fi

    byedpi_installed=0
    if is_byedpi_installed; then
        byedpi_installed=1
        byedpi_version="$(get_byedpi_package_version)"
        [ -z "$byedpi_version" ] && byedpi_version="unknown"
    else
        byedpi_version="not installed"
    fi

    if [ -f /etc/os-release ]; then
        openwrt_version=$(grep OPENWRT_RELEASE /etc/os-release | cut -d'"' -f2)
        [ -z "$openwrt_version" ] && openwrt_version="unknown"
    else
        openwrt_version="unknown"
    fi

    if [ -f /tmp/sysinfo/model ]; then
        device_model=$(cat /tmp/sysinfo/model)
        [ -z "$device_model" ] && device_model="unknown"
    else
        device_model="unknown"
    fi

    generated_at="$(date +%s 2>/dev/null)"
    case "$generated_at" in
    '' | *[!0-9]*) generated_at=0 ;;
    esac

    jq -cn \
        --arg podkop_version "$podkop_version" \
        --arg podkop_latest_version "$podkop_latest_version" \
        --arg luci_app_version "$luci_app_version" \
        --arg sing_box_version "$sing_box_version" \
        --argjson sing_box_extended "$sing_box_extended" \
        --arg zapret_version "$zapret_version" \
        --argjson zapret_installed "$zapret_installed" \
        --arg byedpi_version "$byedpi_version" \
        --argjson byedpi_installed "$byedpi_installed" \
        --arg openwrt_version "$openwrt_version" \
        --arg device_model "$device_model" \
        --argjson generated_at "$generated_at" \
        '{
            podkop_version: $podkop_version,
            podkop_latest_version: $podkop_latest_version,
            luci_app_version: $luci_app_version,
            sing_box_version: $sing_box_version,
            sing_box_extended: $sing_box_extended,
            zapret_version: $zapret_version,
            zapret_installed: $zapret_installed,
            byedpi_version: $byedpi_version,
            byedpi_installed: $byedpi_installed,
            openwrt_version: $openwrt_version,
            device_model: $device_model,
            generated_at: $generated_at
        }'
}

refresh_system_info_cache() {
    local system_info

    system_info="$(build_system_info)" || return 1
    [ -n "$system_info" ] || return 1

    printf '%s\n' "$system_info" | write_system_info_cache
}

get_system_info() {
    local system_info

    if system_info_cache_is_valid; then
        cat "$PODKOP_SYSTEM_INFO_CACHE_FILE"
        return 0
    fi

    system_info="$(build_system_info)" || return 1
    [ -n "$system_info" ] || return 1

    printf '%s\n' "$system_info" | write_system_info_cache
    printf '%s\n' "$system_info"
}

