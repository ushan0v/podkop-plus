}

show_system_info() {
    echo "=== OpenWrt Version ==="
    grep OPENWRT_RELEASE /etc/os-release | cut -d'"' -f2
    echo
    echo "=== Device Model ==="
    cat /tmp/sysinfo/model
}

fetch_latest_podkop_version() {
    command -v curl >/dev/null 2>&1 || return 1

    curl --connect-timeout 1 -m 2 -fsSL "https://api.github.com/repos/$PODKOP_RELEASE_REPO/releases/latest" 2>/dev/null |
        sed -n 's/^[[:space:]]*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' |
        head -n 1
}

write_podkop_latest_version_cache() {
    local value="$1"
    local timestamp="$2"
    local cache_file="/tmp/podkop-plus.latest-version.cache"

    [ -n "$value" ] || return 0

    {
        printf '%s\n' "$value"
        printf '%s\n' "$timestamp"
    } > "$cache_file"
}

refresh_podkop_latest_version_cache() {
    local fetched_value now

    fetched_value="$(fetch_latest_podkop_version)"
    [ -n "$fetched_value" ] || return 0

    now="$(date +%s 2>/dev/null)"
    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    write_podkop_latest_version_cache "$fetched_value" "$now"
}

get_podkop_latest_version() {
    local cache_file="/tmp/podkop-plus.latest-version.cache"
    local cache_ttl=21600
    local now cache_value cache_timestamp cache_is_recent

    now="$(date +%s 2>/dev/null)"
    cache_value="$(sed -n '1p' "$cache_file" 2>/dev/null)"
    cache_timestamp="$(sed -n '2p' "$cache_file" 2>/dev/null)"

    case "$now" in
    '' | *[!0-9]*) now=0 ;;
    esac

    case "$cache_timestamp" in
    '' | *[!0-9]*) cache_timestamp=0 ;;
    esac

    cache_is_recent=0
    if [ -n "$cache_value" ] && [ "$now" -gt 0 ] &&
        [ $((now - cache_timestamp)) -lt "$cache_ttl" ]; then
        cache_is_recent=1
    fi

    if [ "$cache_is_recent" -eq 1 ] &&
        is_min_package_version "$cache_value" "$PODKOP_VERSION"; then
        echo "$cache_value"
        return 0
    fi

    (refresh_podkop_latest_version_cache) >/dev/null 2>&1 &

    if [ "$cache_is_recent" -eq 1 ] && [ -n "$cache_value" ]; then
        echo "$PODKOP_VERSION"
        return 0
    fi

    if [ -n "$cache_value" ]; then
        echo "$cache_value"
        return 0
    fi

    echo "unknown"
}

get_system_info() {
    local podkop_version podkop_latest_version luci_app_version sing_box_version zapret_version zapret_installed openwrt_version device_model

    podkop_version="$PODKOP_VERSION"

    podkop_latest_version="$(get_podkop_latest_version)"
    [ -n "$podkop_latest_version" ] || podkop_latest_version="unknown"

    if [ -f "$PODKOP_LUCI_VIEW_DIR/main.js" ]; then
        luci_app_version=$(grep 'var PODKOP_LUCI_APP_VERSION' "$PODKOP_LUCI_VIEW_DIR/main.js" | cut -d'"' -f2)
    else
        luci_app_version="not installed"
    fi

    if command -v sing-box > /dev/null 2>&1; then
        sing_box_version=$(sing-box version 2> /dev/null | head -n 1 | awk '{print $3}')
        [ -z "$sing_box_version" ] && sing_box_version="unknown"
    else
        sing_box_version="not installed"
    fi

    zapret_installed=0
    if is_zapret_installed; then
        zapret_installed=1
        zapret_version="$(get_zapret_package_version)"
        [ -z "$zapret_version" ] && zapret_version="unknown"
    else
        zapret_version="not installed"
    fi

    if [ -f /etc/os-release ]; then
        openwrt_version=$(grep OPENWRT_RELEASE /etc/os-release | cut -d'"' -f2)
        [ -z "$openwrt_version" ] && openwrt_version="unknown"
    else
        openwrt_version="unknown"
    fi

    if [ -f /tmp/sysinfo/model ]; then
        device_model=$(cat /tmp/sysinfo/model)
        [ -z "$device_model" ] && device_model="unknown"
    else
        device_model="unknown"
    fi

    jq -cn \
        --arg podkop_version "$podkop_version" \
        --arg podkop_latest_version "$podkop_latest_version" \
        --arg luci_app_version "$luci_app_version" \
        --arg sing_box_version "$sing_box_version" \
        --arg zapret_version "$zapret_version" \
        --argjson zapret_installed "$zapret_installed" \
        --arg openwrt_version "$openwrt_version" \
        --arg device_model "$device_model" \
        '{
            podkop_version: $podkop_version,
            podkop_latest_version: $podkop_latest_version,
            luci_app_version: $luci_app_version,
            sing_box_version: $sing_box_version,
            zapret_version: $zapret_version,
            zapret_installed: $zapret_installed,
            openwrt_version: $openwrt_version,
            device_model: $device_model
        }'
}

